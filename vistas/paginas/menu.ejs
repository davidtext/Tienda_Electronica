<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Control - Sistema POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

    <%- include('../componentes/navbar') %>

    <div class="container-fluid px-4 py-4">

        <% if (alertasStock.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show fw-bold shadow-sm d-flex align-items-center" role="alert">
                <i class="fa-solid fa-triangle-exclamation fs-4 me-3"></i> 
                <div>
                    ¡Atención! Tienes <strong><%= alertasStock.length %></strong> producto(s) con stock bajo o agotado. Revisa el panel de alertas.
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold m-0"><i class="fa-solid fa-chart-line text-primary me-2"></i>Panel de ventas</h2>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm border-start border-success border-5 h-100">
                    <div class="card-body">
                        <p class="text-muted fw-bold mb-1">VENTAS DE HOY</p>
                        <h3 class="fw-bold text-success m-0">$<%= Number(metricas.ventasHoy).toLocaleString('es-AR') %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm border-start border-primary border-5 h-100">
                    <div class="card-body">
                        <p class="text-muted fw-bold mb-1">VENTAS DEL MES</p>
                        <h3 class="fw-bold text-primary m-0">$<%= Number(metricas.ventasMes).toLocaleString('es-AR') %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm border-start border-warning border-5 h-100">
                    <div class="card-body">
                        <p class="text-muted fw-bold mb-1">CLIENTES REGISTRADOS</p>
                        <h3 class="fw-bold text-body m-0"><i class="fa-solid fa-users text-warning me-2"></i><%= metricas.totalClientes %></h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header pt-3 pb-2 border-0">
                        <h6 class="fw-bold m-0"><i class="fa-solid fa-chart-bar me-2"></i>Ventas de los últimos 7 días</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="graficoVentas" height="100"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-flex flex-column gap-4">
                
                <div class="card border-0 shadow-sm flex-fill">
                    <div class="card-header pt-3 pb-2 border-0 border-bottom">
                        <h6 class="fw-bold m-0"><i class="fa-solid fa-trophy text-warning me-2"></i>Top 5 Más Vendidos</h6>
                    </div>
                    <ul class="list-group list-group-flush">
                        <% if (topProductos.length > 0) { %>
                            <% topProductos.forEach((prod, index) => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span class="small fw-semibold"><%= index + 1 %>. <%= prod.nombre %></span>
                                    <span class="badge bg-primary rounded-pill"><%= prod.total_vendido %> un.</span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="list-group-item text-center text-muted small py-3">Aún no hay ventas registradas.</li>
                        <% } %>
                    </ul>
                </div>

                <div class="card border-0 shadow-sm flex-fill">
                    <div class="card-header bg-danger text-white pt-3 pb-2 border-0">
                        <h6 class="fw-bold m-0"><i class="fa-solid fa-triangle-exclamation me-2"></i>Alertas de Stock Crítico</h6>
                    </div>
                    <ul class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                        <% if (alertasStock.length > 0) { %>
                            <% alertasStock.forEach(prod => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center bg-danger-subtle border-bottom border-danger">
                                    <span class="small fw-bold text-danger"><%= prod.nombre %></span>
                                    <span class="badge bg-danger">Quedan: <%= prod.stock_actual %></span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="list-group-item text-center text-success fw-bold small py-3"><i class="fa-solid fa-check-circle me-1"></i>Stock saludable</li>
                        <% } %>
                    </ul>
                </div>

            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
            
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-body-tertiary pt-3 pb-2 border-0 border-bottom">
                        <h6 class="fw-bold m-0"><i class="fa-solid fa-medal text-warning me-2"></i>Mejores Vendedores (Mes Actual)</h6>
                    </div>
                    <ul class="list-group list-group-flush">
                        <% if (rankingVendedores.length > 0) { %>
                            <% rankingVendedores.forEach((vend, index) => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <% if(index === 0) { %>
                                            <i class="fa-solid fa-crown text-warning me-2 fs-5"></i>
                                        <% } else { %>
                                            <span class="text-muted fw-bold me-3"><%= index + 1 %></span>
                                        <% } %>
                                        <span class="fw-semibold"><%= vend.nombre %> <%= vend.apellido %></span>
                                    </div>
                                    <div class="text-end">
                                        <span class="d-block fw-bold text-success">$<%= Number(vend.total_recaudado).toLocaleString('es-AR') %></span>
                                        <span class="badge bg-secondary rounded-pill"><%= vend.cantidad_ventas %> ventas</span>
                                    </div>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="list-group-item text-center text-muted small py-4">Aún no hay ventas este mes.</li>
                        <% } %>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-body-tertiary pt-3 pb-2 border-0 border-bottom">
                        <h6 class="fw-bold m-0"><i class="fa-solid fa-clock-rotate-left text-info me-2"></i>Actividad Reciente</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                            <% if (feedActividad.length > 0) { %>
                                <% feedActividad.forEach(act => { %>
                                    <li class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between mb-1">
                                            <strong class="small text-primary"><%= act.empleado_nombre %> <%= act.empleado_apellido %></strong>
                                            <small class="text-muted"><%= new Date(act.fecha_hora).toLocaleString('es-AR', { hour: '2-digit', minute:'2-digit', day:'2-digit', month:'2-digit' }) %></small>
                                        </div>
                                        <p class="mb-0 small text-body">
                                            <span class="badge bg-secondary me-1"><%= act.accion %></span> 
                                            <%= act.detalle || 'Modificó ' + act.tabla_afectada %>
                                        </p>
                                    </li>
                                <% }) %>
                            <% } else { %>
                                <li class="list-group-item text-center text-muted small py-5">
                                    <i class="fa-solid fa-ghost fs-3 mb-2 d-block text-light-emphasis"></i>
                                    No hay actividad reciente registrada en el sistema.
                                </li>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>
            
        </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Traemos los datos ocultos desde Node
            const rawData = <%- ventas7Dias %>;
            
            // Armamos los arreglos para el gráfico
            const fechas = [];
            const totales = [];

            rawData.forEach(item => {
                // Formateamos la fecha a DD/MM
                const fechaCorta = new Date(item.fecha).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit' });
                fechas.push(fechaCorta);
                totales.push(parseFloat(item.total));
            });

            // Dibujamos el gráfico
            const ctx = document.getElementById('graficoVentas').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: fechas,
                    datasets: [{
                        label: 'Recaudación ($)',
                        data: totales,
                        backgroundColor: '#0d6efd',
                        borderRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false } 
                    },
                    scales: {
                        x: {
                            ticks: { color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#adb5bd' : '#6c757d' },
                            grid: { color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#343a40' : '#e9ecef' }
                        },
                        y: { 
                            beginAtZero: true,
                            ticks: { color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#adb5bd' : '#6c757d' },
                            grid: { color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#343a40' : '#e9ecef' }
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>