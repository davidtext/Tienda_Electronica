<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cambiar Password Obligatorio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light d-flex justify-content-center align-items-center vh-100">

    <div class="container" style="max-width: 500px;">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-warning text-dark text-center py-3">
                <h4 class="mb-0">⚠️ Cambio de Contraseña</h4>
                <small>Por seguridad, debes cambiar tu clave temporal.</small>
            </div>

            <div class="card-body p-4">
                <form action="/guardar-nueva-password" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Nueva Contraseña</label>
                        <input type="password" name="password_nueva" class="form-control" required minlength="6">
                        <small class="text-muted">Mínimo 6 caracteres.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirmar Contraseña</label>
                        <input type="password" name="password_confirmacion" class="form-control" required minlength="6">
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">Guardar y Volver al Login</button>
                </form>
            </div>
        </div>
    </div>

</body>

</html>