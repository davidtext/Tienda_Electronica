<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingreso de Stock</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body>

    <%- include('../componentes/navbar') %>

        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">

                    <h2 class="mb-4 text-primary fw-bold">
                        <i class="fa-solid fa-truck-ramp-box me-2"></i>Ingreso de Productos
                    </h2>

                    <div class="card shadow-sm border mb-4 bg-body-tertiary">
                        <div class="card-body p-4 rounded">
                            <label class="form-label text-body-secondary fw-bold">Escanear Código de Barras o Buscar por
                                Nombre</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-primary text-white border-primary"><i
                                        class="fa-solid fa-barcode"></i></span>
                                <input type="text" id="inputBusqueda" class="form-control border-primary"
                                    placeholder="Ej: AS-NB-001 o Asus..." autofocus>
                                <button class="btn btn-primary fw-bold" type="button" id="btnBuscar">Buscar</button>
                            </div>
                            <small class="text-body-secondary mt-2 d-block">Presiona Enter después de escribir para
                                buscar rápidamente.</small>
                        </div>
                    </div>

                    <div class="card shadow-sm border d-none" id="panelIngreso">
                        <div class="card-header bg-success text-white border-bottom-0">
                            <h5 class="mb-0"><i class="fa-solid fa-circle-check me-2"></i>Producto Encontrado</h5>
                        </div>
                        <div class="card-body p-4 bg-body">

                            <div class="alert bg-body-secondary border border-secondary-subtle mb-4">
                                <h4 id="productoNombre" class="fw-bold text-body mb-1">Nombre del Producto</h4>
                                <p class="mb-0 text-body-secondary">SKU: <span id="productoSku" class="fw-bold"></span>
                                </p>
                                <hr class="border-secondary-subtle">
                                <h5 class="mb-0 text-primary">Stock Actual: <span id="productoStock"
                                        class="fw-bold fs-4">0</span> unidades</h5>
                            </div>

                            <form id="formIngresoStock">
                                <input type="hidden" id="productoId">

                                <div class="row align-items-center">
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label text-body fw-bold">Cant. a Ingresar *</label>
                                        <input type="number" id="cantidadIngreso"
                                            class="form-control form-control-lg border-primary" min="1" required>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label text-body fw-bold">Costo Unitario ($) *</label>
                                        <input type="text" id="costoIngreso"
                                            class="form-control form-control-lg input-precio" placeholder="0,00"
                                            required>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label text-body fw-bold">Nuevo Precio Venta</label>
                                        <input type="text" id="nuevoPrecioVenta"
                                            class="form-control form-control-lg border-warning input-precio"
                                            placeholder="Opcional">
                                        <small class="text-muted fw-bold">Actual: $<span id="precioActualTexto"
                                                class="text-primary">0</span></small>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold mt-2">
                                    <i class="fa-solid fa-plus me-2"></i>Sumar al Inventario
                                </button>
                            </form>

                        </div>
                    </div>

                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script src="/assets/js/stock_ingresos.js"></script>

</body>

</html>