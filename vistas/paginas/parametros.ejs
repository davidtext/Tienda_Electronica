<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración de Parámetros</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body>

    <%- include('../componentes/navbar') %>

    <div class="container-fluid mt-4 px-4">
        <h2 class="mb-4 text-primary fw-bold"><i class="fa-solid fa-tags me-2"></i>Atributos de Productos</h2>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fa-solid fa-list me-2"></i>Categorías</h5>
                    </div>
                    <div class="card-body d-flex flex-column">
                        
                        <div class="input-group mb-3">
                            <input type="text" id="nuevaCategoria" class="form-control" placeholder="Nombre de nueva categoría...">
                            <button class="btn btn-success fw-bold" onclick="guardar('categorias', null, 'nuevaCategoria')">
                                <i class="fa-solid fa-plus"></i> Agregar
                            </button>
                        </div>

                        <form action="/parametros" method="GET" class="mb-3 d-flex">
                            <input type="hidden" name="p_mar" value="<%= pMar %>">
                            <input type="hidden" name="b_mar" value="<%= bMar %>">
                            <input type="text" name="b_cat" class="form-control me-2" placeholder="Buscar categoría..." value="<%= bCat %>">
                            <button type="submit" class="btn btn-outline-primary"><i class="fa-solid fa-search"></i></button>
                        </form>

                        <div class="table-responsive flex-grow-1">
                            <table class="table table-hover align-middle border">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% categorias.forEach(c => { %>
                                        <tr>
                                            <td class="text-muted">#<%= c.id %></td>
                                            <td class="fw-bold"><%= c.nombre %></td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary" onclick="editar('categorias', <%= c.id %>, '<%= c.nombre %>')"><i class="fa-solid fa-pen"></i></button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="borrar('categorias', <%= c.id %>, '<%= c.nombre %>')"><i class="fa-solid fa-trash"></i></button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                    <% if (categorias.length === 0) { %>
                                        <tr><td colspan="3" class="text-center text-muted py-3">No hay categorías.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <% if (totPagCat > 1) { %>
                            <nav class="mt-3">
                                <ul class="pagination pagination-sm justify-content-center mb-0">
                                    <% for (let i = 1; i <= totPagCat; i++) { %>
                                        <li class="page-item <%= pCat === i ? 'active' : '' %>">
                                            <a class="page-link" href="?p_cat=<%= i %>&b_cat=<%= bCat %>&p_mar=<%= pMar %>&b_mar=<%= bMar %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                </ul>
                            </nav>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fa-solid fa-copyright me-2"></i>Marcas</h5>
                    </div>
                    <div class="card-body d-flex flex-column">
                        
                        <div class="input-group mb-3">
                            <input type="text" id="nuevaMarca" class="form-control" placeholder="Nombre de nueva marca...">
                            <button class="btn btn-success fw-bold" onclick="guardar('marcas', null, 'nuevaMarca')">
                                <i class="fa-solid fa-plus"></i> Agregar
                            </button>
                        </div>

                        <form action="/parametros" method="GET" class="mb-3 d-flex">
                            <input type="hidden" name="p_cat" value="<%= pCat %>">
                            <input type="hidden" name="b_cat" value="<%= bCat %>">
                            <input type="text" name="b_mar" class="form-control me-2" placeholder="Buscar marca..." value="<%= bMar %>">
                            <button type="submit" class="btn btn-outline-primary"><i class="fa-solid fa-search"></i></button>
                        </form>

                        <div class="table-responsive flex-grow-1">
                            <table class="table table-hover align-middle border">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% marcas.forEach(m => { %>
                                        <tr>
                                            <td class="text-muted">#<%= m.id %></td>
                                            <td class="fw-bold"><%= m.nombre %></td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary" onclick="editar('marcas', <%= m.id %>, '<%= m.nombre %>')"><i class="fa-solid fa-pen"></i></button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="borrar('marcas', <%= m.id %>, '<%= m.nombre %>')"><i class="fa-solid fa-trash"></i></button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                    <% if (marcas.length === 0) { %>
                                        <tr><td colspan="3" class="text-center text-muted py-3">No hay marcas.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <% if (totPagMar > 1) { %>
                            <nav class="mt-3">
                                <ul class="pagination pagination-sm justify-content-center mb-0">
                                    <% for (let i = 1; i <= totPagMar; i++) { %>
                                        <li class="page-item <%= pMar === i ? 'active' : '' %>">
                                            <a class="page-link" href="?p_mar=<%= i %>&b_mar=<%= bMar %>&p_cat=<%= pCat %>&b_cat=<%= bCat %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                </ul>
                            </nav>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        // FUNCIÓN UNIVERSAL PARA CREAR O EDITAR
        function guardar(tipo, id, inputElementId = null, nombreDirecto = null) {
            let nombre = inputElementId ? document.getElementById(inputElementId).value : nombreDirecto;

            if (!nombre || nombre.trim() === '') {
                return Swal.fire('Error', 'El campo no puede estar vacío.', 'warning');
            }

            fetch('/parametros/guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tipo, id, nombre })
            })
            .then(res => res.json())
            .then(data => {
                if (data.status === 'success') location.reload();
                else Swal.fire('Atención', data.message, 'error');
            });
        }

        // USAMOS SWEETALERT PARA EDITAR SIN NECESIDAD DE MODALES HTML
        function editar(tipo, id, nombreActual) {
            Swal.fire({
                title: `Editar ${tipo === 'categorias' ? 'Categoría' : 'Marca'}`,
                input: 'text',
                inputValue: nombreActual,
                showCancelButton: true,
                confirmButtonText: 'Guardar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    guardar(tipo, id, null, result.value);
                }
            });
        }

        // FUNCIÓN DE BORRADO
        function borrar(tipo, id, nombre) {
            Swal.fire({
                title: `¿Borrar ${nombre}?`,
                text: "Si hay productos usando esto, el sistema cancelará la operación por seguridad.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Sí, borrar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/parametros/borrar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ tipo, id })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.status === 'success') location.reload();
                        else Swal.fire('Acción Bloqueada', data.message, 'error');
                    });
                }
            });
        }
    </script>
</body>
</html>