<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Botón de Arrepentimiento - Tienda Electrónica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body class="bg-body-tertiary d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg bg-primary text-white shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-white" href="/tienda"><i class="fa-solid fa-arrow-left me-2"></i> Volver
                a la tienda</a>
        </div>
    </nav>

    <div class="container my-5 flex-grow-1">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-body">
                    <div class="text-center mb-4">
                        <i class="fa-solid fa-rotate-left fa-3x text-primary mb-3"></i>
                        <h3 class="fw-bold">Solicitud de Arrepentimiento</h3>
                        <p class="text-muted">Tienes derecho a devolver tu compra dentro de los 10 días corridos desde
                            que recibiste el producto, siempre que se encuentre en las mismas condiciones en las que fue
                            entregado.</p>
                    </div>

                    <form id="formArrepentimiento" onsubmit="enviarArrepentimiento(event)">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Número de Pedido (Ticket)</label>
                            <input type="number" name="id_venta" class="form-control" placeholder="Ej: 125" required>
                            <div class="form-text">Puedes encontrar este número en el comprobante enviado a tu email.
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico de la compra</label>
                            <input type="email" name="email" class="form-control" placeholder="tu@email.com"
                                value="<%= cliente ? cliente.email : '' %>" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Motivo de la devolución (Opcional)</label>
                            <textarea name="motivo" class="form-control" rows="3"
                                placeholder="Cuéntanos por qué deseas devolverlo..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Enviar Solicitud</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function enviarArrepentimiento(e) {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);

        Swal.fire({ title: 'Procesando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

        fetch('/api/tienda/arrepentimiento', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(res => {
            if(res.status === 'success') {
                Swal.fire('¡Solicitud Recibida!', res.message, 'success').then(() => window.location.href = '/tienda');
            } else {
                Swal.fire('Error', res.message, 'error');
            }
        });
    }
</script>
    
</body>

</html>