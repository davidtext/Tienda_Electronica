<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Tienda Electrónica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light d-flex justify-content-center align-items-center vh-100">

    <div class="card bg-secondary p-4 shadow-lg border-0" style="width: 25rem; border-radius: 12px;">
        <h3 class="text-center mb-4 fw-bold">Acceso al Sistema</h3>
        
        <form id="formLogin">
            <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Correo Electrónico</label>
                <input type="email" class="form-control" id="email" name="email_acceso" required>
            </div>
            <div class="mb-4">
                <label for="password" class="form-label fw-semibold">Contraseña</label>
                <input type="password" class="form-control" id="password" name="password" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-bold fs-5 shadow-sm">Ingresar</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        document.getElementById('formLogin').addEventListener('submit', function(e) {
            e.preventDefault(); // Congelamos la página para que no recargue

            // Recolectamos los datos que escribió el usuario
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);

            // Los mandamos por el tubo de ventilación (AJAX) a Node.js
            fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(respuesta => {
                // Node.js nos responde. ¿Fue un error?
                if (respuesta.status === 'error') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Acceso Denegado',
                        text: respuesta.message,
                        confirmButtonColor: '#dc3545',
                        background: '#2b3035', // Modo oscuro para la alerta
                        color: '#fff'
                    });
                } 
                // ¿Fue un éxito?
                else if (respuesta.status === 'success') {
                    // Lo dejamos entrar llevándolo a la ruta que mandó Node (/menu)
                    window.location.href = respuesta.redirect;
                }
            })
            .catch(error => {
                console.error('Error de conexión:', error);
                Swal.fire('Error', 'No se pudo conectar con el servidor', 'error');
            });
        });
    </script>

</body>
</html>