<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportes Financieros - Sistema POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body>

    <%- include('../componentes/navbar') %>

    <div class="container-fluid px-4 py-4" id="areaReporte">
        
        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
            <div>
                <h2 class="fw-bold m-0 text-body"><i class="fa-solid fa-sack-dollar text-success me-2"></i>Reportes Financieros</h2>
                <p class="text-body-secondary mb-0">Análisis de rentabilidad e ingresos del negocio.</p>
                <div class="mt-2" data-html2canvas-ignore="true">
                    <button class="btn btn-success btn-sm fw-bold me-2 shadow-sm" onclick="exportarExcel()"><i class="fa-solid fa-file-excel me-1"></i> Excel</button>
                    <button class="btn btn-danger btn-sm fw-bold shadow-sm" onclick="exportarPDF()"><i class="fa-solid fa-file-pdf me-1"></i> PDF</button>
                </div>
            </div>

            <form action="/reportes" method="GET" class="d-flex gap-2 align-items-end bg-body-tertiary p-3 rounded shadow-sm border border-secondary-subtle" data-html2canvas-ignore="true">
                <div>
                    <label class="form-label fw-bold small text-body-secondary mb-1">Desde:</label>
                    <input type="date" name="desde" class="form-control form-control-sm" value="<%= fechaInicio %>" required>
                </div>
                <div>
                    <label class="form-label fw-bold small text-body-secondary mb-1">Hasta:</label>
                    <input type="date" name="hasta" class="form-control form-control-sm" value="<%= fechaFin %>" required>
                </div>
                <button type="submit" class="btn btn-primary btn-sm fw-bold px-3">
                    <i class="fa-solid fa-filter me-1"></i> Filtrar
                </button>
            </form>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm border-start border-primary border-5 h-100 bg-body-tertiary">
                    <div class="card-body">
                        <p class="text-body-secondary fw-bold mb-1 small"><i class="fa-solid fa-arrow-trend-up me-1"></i>INGRESOS BRUTOS</p>
                        <h3 class="fw-bold text-primary m-0" id="datoIngresos">$<%= Number(totales.ingresos).toLocaleString('es-AR') %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm border-start border-danger border-5 h-100 bg-body-tertiary">
                    <div class="card-body">
                        <p class="text-body-secondary fw-bold mb-1 small"><i class="fa-solid fa-boxes-packing me-1"></i>COSTOS (MERCADERÍA)</p>
                        <h3 class="fw-bold text-danger m-0" id="datoCostos">-$<%= Number(totales.costo).toLocaleString('es-AR') %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm border-start border-warning border-5 h-100 bg-body-tertiary">
                    <div class="card-body">
                        <p class="text-body-secondary fw-bold mb-1 small"><i class="fa-solid fa-tags me-1"></i>DESCUENTOS APLICADOS</p>
                        <h3 class="fw-bold text-warning m-0" id="datoDescuentos">-$<%= Number(totales.descuentos).toLocaleString('es-AR') %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm border-start border-success border-5 h-100 bg-body">
                    <div class="card-body">
                        <p class="text-body-secondary fw-bold mb-1 small"><i class="fa-solid fa-hand-holding-dollar me-1"></i>GANANCIA NETA LIMPIA</p>
                        <h3 class="fw-bold text-success m-0" id="datoGanancia">$<%= Number(totales.ganancia_neta).toLocaleString('es-AR') %></h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100 bg-body-tertiary">
                    <div class="card-header pt-3 pb-2 border-0 bg-transparent border-bottom border-secondary-subtle">
                        <h6 class="fw-bold m-0 text-body"><i class="fa-solid fa-wallet text-info me-2"></i>Distribución de Pagos</h6>
                    </div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <% if (chartLabels !== '[]') { %>
                            <div style="width: 100%; max-width: 300px;">
                                <canvas id="graficoPagos"></canvas>
                            </div>
                        <% } else { %>
                            <div class="text-center text-muted py-5">
                                <i class="fa-solid fa-chart-pie fa-3x mb-3 text-secondary"></i><p>No hay pagos.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100 bg-body-tertiary">
                    <div class="card-header pt-3 pb-2 border-0 bg-transparent border-bottom border-secondary-subtle d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold m-0 text-body"><i class="fa-solid fa-ranking-star text-warning me-2"></i>Top 15: Productos más Rentables</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 text-center" id="tablaRentabilidad">
                                <thead class="table-dark">
                                    <tr>
                                        <th class="text-start ps-3">Producto</th>
                                        <th>Cant.</th>
                                        <th>Ingresos</th>
                                        <th>Costos</th>
                                        <th class="text-success">Ganancia Neta</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-body">
                                    <% if (ranking.length > 0) { %>
                                        <% ranking.forEach((prod, index) => { %>
                                            <tr>
                                                <td class="text-start ps-3 fw-bold"><%= prod.nombre %></td>
                                                <td><%= prod.unidades_vendidas %></td>
                                                <td class="text-primary fw-semibold">$<%= Number(prod.ingresos_generados).toLocaleString('es-AR') %></td>
                                                <td class="text-danger fw-semibold">-$<%= Number(prod.unidades_vendidas * prod.costo_unitario).toLocaleString('es-AR') %></td>
                                                <td class="text-success fw-bold bg-success-subtle">$<%= Number(prod.ganancia_neta).toLocaleString('es-AR') %></td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="py-4 text-muted">No hay ventas registradas.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // 1. Gráfico de ChartJS
        document.addEventListener('DOMContentLoaded', function() {
            const labelsData = <%- chartLabels %>;
            const amountsData = <%- chartData %>;
            if (labelsData.length > 0) {
                const ctx = document.getElementById('graficoPagos').getContext('2d');
                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labelsData,
                        datasets: [{
                            data: amountsData,
                            backgroundColor: ['#198754', '#0dcaf0', '#0d6efd', '#ffc107', '#6c757d'],
                            borderWidth: 2, borderColor: isDark ? '#212529' : '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true, cutout: '65%',
                        plugins: { legend: { position: 'bottom', labels: { color: isDark ? '#fff' : '#000' } } }
                    }
                });
            }
        });

        // 2. Exportar a PDF
        function exportarPDF() {
            const elemento = document.getElementById('areaReporte');
            const opciones = {
                margin: 0.5,
                filename: 'Reporte_Financiero.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, ignoreElements: (el) => el.hasAttribute('data-html2canvas-ignore') },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'landscape' }
            };
            html2pdf().set(opciones).from(elemento).save();
        }

        // 3. Exportar a Excel
        function exportarExcel() {
            // Creamos un libro de Excel
            let wb = XLSX.utils.book_new();
            
            // Creamos una hoja con el resumen
            let resumen = [
                ["INDICADOR", "MONTO"],
                ["Ingresos Brutos", document.getElementById('datoIngresos').innerText],
                ["Costos Mercadería", document.getElementById('datoCostos').innerText],
                ["Descuentos", document.getElementById('datoDescuentos').innerText],
                ["Ganancia Neta", document.getElementById('datoGanancia').innerText]
            ];
            let wsResumen = XLSX.utils.aoa_to_sheet(resumen);
            XLSX.utils.book_append_sheet(wb, wsResumen, "Resumen General");

            // Agarramos la tabla de rentabilidad del DOM y la metemos en otra pestaña
            let tabla = document.getElementById('tablaRentabilidad');
            let wsTabla = XLSX.utils.table_to_sheet(tabla);
            XLSX.utils.book_append_sheet(wb, wsTabla, "Top Productos");

            XLSX.writeFile(wb, 'Reporte_Financiero.xlsx');
        }
    </script>
</body>
</html>