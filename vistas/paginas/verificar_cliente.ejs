<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verificar Cuenta - Tienda Online</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .input-codigo {
            font-size: 2rem;
            letter-spacing: 15px;
            text-align: center;
            font-weight: bold;
        }
    </style>
</head>
<body class="bg-dark text-light d-flex justify-content-center align-items-center vh-100">

    <div class="card bg-secondary p-5 shadow-lg border-0 text-center" style="width: 28rem; border-radius: 12px;">
        <i class="fa-solid fa-envelope-open-text text-primary mb-3" style="font-size: 4rem;"></i>
        <h4 class="fw-bold text-white mb-2">Revisá tu correo</h4>
        <p class="text-light opacity-75 small mb-4">Enviamos un código de 6 dígitos a <strong><%= email %></strong>. Ingresalo abajo para activar tu cuenta.</p>
        
        <div class="mb-4">
            <input type="text" id="codigoInput" class="form-control input-codigo shadow-sm" maxlength="6" placeholder="------" autocomplete="off">
        </div>
        
        <button class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" onclick="validarCodigo()">
            Verificar mi cuenta <i class="fa-solid fa-check ms-1"></i>
        </button>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function validarCodigo() {
            const codigo = document.getElementById('codigoInput').value.trim();
            
            if (codigo.length !== 6) {
                return Swal.fire('Atención', 'El código debe tener exactamente 6 números.', 'warning');
            }

            fetch('/api/tienda/verificar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ codigo: codigo })
            })
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Bienvenido!',
                        text: 'Tu cuenta ha sido activada correctamente.',
                        confirmButtonText: 'Ir a comprar',
                        allowOutsideClick: false
                    }).then(() => {
                        // Lo mandamos al checkout o a la tienda, ya logueado
                        window.location.href = '/tienda/checkout';
                    });
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            })
            .catch(err => console.error(err));
        }
    </script>
</body>
</html>