<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Compras - Tienda Online</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body class="bg-body-tertiary">

    <nav class="navbar navbar-expand-lg bg-body shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/tienda">🛒 Tienda Online</a>
            <div class="navbar-nav ms-auto align-items-center gap-3">
                <a href="/tienda" class="btn btn-sm btn-outline-secondary fw-bold"><i
                        class="fa-solid fa-arrow-left me-1"></i> Volver al catálogo</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <h3 class="fw-bold text-body mb-4"><i class="fa-solid fa-box-open text-primary me-2"></i>Mis Compras</h3>

        <div class="row">
            <div class="col-lg-12">
                <% if (compras && compras.length> 0) { %>
                    <div class="d-flex flex-column gap-3">
                        <% compras.forEach(compra=> { %>
                            <div class="card border-secondary-subtle shadow-sm">
                                <div
                                    class="card-header bg-body border-bottom border-secondary-subtle d-flex justify-content-between align-items-center py-3">
                                    <div>
                                        <span class="text-muted small d-block">Fecha de compra</span>
                                        <span class="fw-bold">
                                            <%= new Date(compra.fecha_venta).toLocaleDateString('es-AR', {
                                                day: '2-digit' , month: 'long' , year: 'numeric' }) %>
                                        </span>
                                    </div>
                                    <div class="text-end">
                                        <span class="text-muted small d-block">Total</span>
                                        <span class="fw-bold text-success fs-5">$<%=
                                                Number(compra.total_venta).toLocaleString('es-AR') %></span>
                                    </div>
                                    <div class="text-end d-none d-md-block">
                                        <span class="text-muted small d-block">Nro. de Orden</span>
                                        <span class="fw-bold text-body-secondary">#<%= compra.id %></span>
                                    </div>
                                </div>
                                <div
                                    class="card-body bg-body-tertiary d-flex justify-content-between align-items-center">
                                    <div>
                                        <div>
                                            <% if (compra.estado_envio==='Pendiente de Despacho' ) { %>

                                                <h5 class="text-warning fw-bold m-0">
                                                    <i class="fa-solid fa-clock me-2"></i>Preparando tu pedido
                                                </h5>

                                                <% if (compra.FK_direccion_envio) { %>
                                                    <p class="text-muted small m-0 mt-1">
                                                        Estamos preparando tu paquete para enviarlo a tu domicilio.
                                                    </p>
                                                    <% } else { %>
                                                        <p class="text-muted small m-0 mt-1">
                                                            Estamos preparando tus productos para que pases a retirarlos
                                                            por el local.
                                                        </p>
                                                        <% } %>

                                                            <% } else if (compra.estado_envio==='Cancelado por Cliente'
                                                                ) { %>

                                                                <h5 class="text-danger fw-bold m-0">
                                                                    <i class="fa-solid fa-ban me-2"></i>Pedido cancelado
                                                                </h5>

                                                                <% } else if (compra.estado_envio==='Entregado' ) { %>

                                                                    <h5 class="text-success fw-bold m-0">
                                                                        <i
                                                                            class="fa-solid fa-circle-check me-2"></i>Pedido
                                                                        entregado
                                                                    </h5>

                                                                    <% } %>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <a href="/tienda/mis-compras/<%= compra.id %>"
                                            class="btn btn-outline-primary btn-sm fw-bold">Ver detalle</a>

                                        <% if (compra.estado_envio==='Pendiente de Despacho' ) { %>
                                            <button onclick="cancelarPedido(<%= compra.id %>)"
                                                class="btn btn-outline-danger btn-sm fw-bold"><i
                                                    class="fa-solid fa-xmark"></i> Cancelar</button>
                                            <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div class="text-center py-5 bg-body rounded-3 shadow-sm border border-secondary-subtle">
                            <i class="fa-solid fa-bag-shopping fa-4x text-muted mb-3"></i>
                            <h4 class="fw-bold text-body">Aún no tienes compras</h4>
                            <p class="text-muted">¡Explora nuestro catálogo y encuentra lo que buscas!</p>
                            <a href="/tienda" class="btn btn-primary fw-bold mt-2">Ir a comprar</a>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const temaGuardado = localStorage.getItem('temaTienda');
        if (temaGuardado === 'dark') document.documentElement.setAttribute('data-bs-theme', 'dark');
        function cancelarPedido(idVenta) {
            Swal.fire({
                title: '¿Cancelar compra?',
                text: "El proceso de reembolso a tu tarjeta se iniciará automáticamente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, cancelar pedido',
                cancelButtonText: 'No, mantener'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Procesando reembolso...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });

                    fetch('/api/tienda/mis-compras/cancelar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id_venta: idVenta })
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.status === 'success') {
                                Swal.fire('¡Cancelado!', data.message, 'success').then(() => window.location.reload());
                            } else {
                                Swal.fire('Atención', data.message, 'error');
                            }
                        });
                }
            });
        }
    </script>
</body>

</html>