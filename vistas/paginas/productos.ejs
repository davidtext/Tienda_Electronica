<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo de Productos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<link rel="stylesheet" href="assets/css/productos.css">
</head>

<body class="bg-body-tertiary">

    <%- include('../componentes/navbar') %>

        <div class="container-fluid mt-4 px-4">
            <div class="row">

                <div class="col-md-3 col-lg-2 mb-4">
                    <h5 class="fw-bold mb-3"><i class="fa-solid fa-list me-2"></i>Categorías</h5>

                    <div class="list-group shadow-sm rounded-3">
                        <a href="/productos"
                            class="list-group-item list-group-item-action fw-semibold <%= !categoriaActual ? 'active' : '' %>">
                            <i class="fa-solid fa-border-all me-2"></i> Ver Todo
                        </a>

                        <% categorias.forEach(function(cat) { %>
                            <a href="/productos?categoria=<%= cat.id %>"
                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center fw-semibold categoria-item <%= categoriaActual == cat.id ? 'active' : '' %>">
                                <span><i class="fa-solid fa-angle-right me-2 small"></i>
                                    <%= cat.nombre %>
                                </span>
                            </a>
                            <% }); %>
                    </div>
                </div>

                <div class="col-md-9 col-lg-10">

                    <div
                        class="d-flex justify-content-between align-items-center mb-4 bg-body p-3 rounded-3 shadow-sm border-start border-primary border-4">
                        <h4 class="m-0 fw-bold text-body">
                            <% if (categoriaActual) { %> Catálogo Filtrado <% } else { %> Destacados de la Tienda <% }
                                        %>
                        </h4>
                        <form class="d-flex gap-2" action="/productos" method="GET">
                            <% if (categoriaActual) { %>
                                <input type="hidden" name="categoria" value="<%= categoriaActual %>">
                                <% } %>

                                    <select name="marca" class="form-select bg-body-tertiary border-secondary-subtle"
                                        style="max-width: 180px;">
                                        <option value="">Todas las Marcas</option>
                                        <% marcas.forEach(function(m) { %>
                                            <option value="<%= m.id %>" <%=marcaActual==m.id ? 'selected' : '' %>>
                                                <%= m.nombre %>
                                            </option>
                                            <% }); %>
                                    </select>

                                    <input class="form-control bg-body-tertiary border-secondary-subtle" type="search"
                                        placeholder="Buscar producto o SKU..." name="busqueda"
                                        value="<%= busquedaActual ? busquedaActual : '' %>">
                                    <button class="btn btn-primary fw-bold px-4" type="submit">Buscar</button>

                                    <% if (busquedaActual || marcaActual || categoriaActual) { %>
                                        <a href="/productos" class="btn btn-outline-danger"
                                            title="Limpiar todos los filtros">
                                            <i class="fa-solid fa-eraser"></i>
                                        </a>
                                        <% } %>
                        </form>
                    </div>

                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                        <% productos.forEach(function(prod) { %>
                            <div class="col">
                                <div class="card h-100 product-card shadow-sm border-secondary-subtle bg-body">

                                    <% if (Number(prod.porcentaje_descuento)> 0) { %>
                                        <span class="badge-descuento shadow-sm">
                                            <%= Math.round(prod.porcentaje_descuento) %>% OFF
                                        </span>
                                        <% } %>

                                            <div class="img-container border-bottom border-secondary-subtle"
                                                style="cursor: pointer;"
                                                onclick="verDetalleProducto('<%= prod.nombre %>', '<%= prod.sku %>', '<%= prod.descripcion ? prod.descripcion.replace(/(\r\n|\n|\r)/gm, '\\n') : '' %>', '<%= prod.imagen ? prod.imagen : 'https://via.placeholder.com/200x200?text=Sin+Imagen' %>')">

                                                <img src="<%= prod.imagen ? prod.imagen : 'https://via.placeholder.com/200x200?text=Sin+Imagen' %>"
                                                    alt="<%= prod.nombre %>">
                                                <div class="position-absolute top-0 end-0 p-2 text-muted"><i
                                                        class="fa-solid fa-expand"></i></div>
                                            </div>

                                            <div class="card-body d-flex flex-column">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <small class="text-primary fw-bold">
                                                        <%= prod.nombre_categoria %>
                                                    </small>

                                                    <% if (prod.stock_actual> 0) { %>
                                                        <span
                                                            class="badge bg-success-subtle text-success border border-success">Stock:
                                                            <%= prod.stock_actual %></span>
                                                        <% } else { %>
                                                            <span class="badge bg-danger">Agotado</span>
                                                            <% } %>
                                                </div>

                                                <h6 class="card-title fw-semibold text-body mb-3"
                                                    style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.4em;"
                                                    title="<%= prod.nombre %>">
                                                    <%= prod.nombre %>
                                                </h6>

                                                <div class="mt-auto">
                                                    <% if (Number(prod.porcentaje_descuento)> 0) { %>
                                                        <small class="text-muted text-decoration-line-through d-block"
                                                            style="font-size: 0.85rem;">
                                                            $<%= Number(prod.precio).toLocaleString('es-AR') %>
                                                        </small>
                                                        <% const precioFinal=prod.precio * (1 -
                                                            (prod.porcentaje_descuento / 100)); %>
                                                            <h4 class="mb-0 text-success fw-bold">
                                                                $<%= Math.round(precioFinal).toLocaleString('es-AR') %>
                                                            </h4>
                                                            <% } else { %>
                                                                <h4 class="mb-0 text-body fw-bold mt-3">
                                                                    $<%= Number(prod.precio).toLocaleString('es-AR') %>
                                                                </h4>
                                                                <% } %>
                                                </div>
                                            </div>

                                            <div class="card-footer bg-body border-0 pt-0 pb-3 px-3">
                                                <button class="btn btn-primary w-100 fw-bold" style="font-size: 0.9rem;"
                                                    onclick="agregarAlCarrito(<%= prod.id %>)" <%=prod.stock_actual <=0
                                                    ? 'disabled' : '' %>>
                                                    <i class="fa-solid fa-cart-plus me-2"></i> Sumar al Carrito
                                                </button>
                                            </div>
                                </div>
                            </div>
                            <% }); %>

                                <% if (productos.length===0) { %>
                                    <div
                                        class="col-12 text-center py-5 bg-body rounded-3 shadow-sm border border-secondary-subtle">
                                        <i class="fa-solid fa-box-open fa-3x text-secondary mb-3"></i>
                                        <h5 class="text-body fw-bold">No hay productos en esta categoría aún.</h5>
                                    </div>
                                    <% } %>
                    </div>
                </div>
            </div>
        </div>

        <% if (totalPaginas> 1) { %>
            <nav aria-label="Navegación de páginas" class="mt-5 mb-4">
                <ul class="pagination justify-content-center shadow-sm">
                    <li class="page-item <%= paginaActual === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="<%= urlBase %>pagina=<%= paginaActual - 1 %>">
                            <i class="fa-solid fa-chevron-left me-1"></i> Anterior
                        </a>
                    </li>
                    <% for (let i=1; i <=totalPaginas; i++) { %>
                        <li class="page-item <%= paginaActual === i ? 'active' : '' %>">
                            <a class="page-link fw-bold" href="<%= urlBase %>pagina=<%= i %>">
                                <%= i %>
                            </a>
                        </li>
                        <% } %>
                            <li class="page-item <%= paginaActual === totalPaginas ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= urlBase %>pagina=<%= paginaActual + 1 %>">
                                    Siguiente <i class="fa-solid fa-chevron-right ms-1"></i>
                                </a>
                            </li>
                </ul>
            </nav>
            <% } %>

                <button
                    class="btn btn-primary shadow-lg position-fixed d-flex justify-content-center align-items-center"
                    style="bottom: 30px; right: 30px; width: 65px; height: 65px; border-radius: 50%; z-index: 1040;"
                    type="button" data-bs-toggle="offcanvas" data-bs-target="#carritoOffcanvas" title="Ver Carrito">
                    <i class="fa-solid fa-cart-shopping fs-3"></i>
                    <span id="contadorCarritoFlotante"
                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light"
                        style="font-size: 0.9rem;">
                        0
                    </span>
                </button>

                <div class="offcanvas offcanvas-end" tabindex="-1" id="carritoOffcanvas">
                    <div class="offcanvas-header bg-dark text-white">
                        <h5 class="offcanvas-title"><i class="fa-solid fa-cart-shopping me-2"></i>Tu Carrito</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                    </div>
                    <div class="offcanvas-body d-flex flex-column">
                        <div id="listaCarrito" class="flex-grow-1 overflow-auto">
                            <p class="text-center text-muted mt-5">El carrito está vacío.</p>
                        </div>
                        <div class="border-top pt-3 mt-3">
                            <div class="d-flex justify-content-between mb-3">
                                <h5 class="fw-bold m-0 text-body">Total:</h5>
                                <h5 class="fw-bold text-success m-0" id="totalCarrito">$0.00</h5>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-danger w-50 fw-bold"
                                    onclick="vaciarCarrito()">
                                    <i class="fa-solid fa-trash me-2"></i>Vaciar
                                </button>
                                <button type="button" class="btn btn-success w-50 fw-bold" onclick="abrirModalCobro()">
                                    Cobrar <i class="fa-solid fa-money-bill-wave ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="modalCobro" aria-hidden="true" data-bs-focus="false">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content border-0 shadow-lg">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title fw-bold"><i class="fa-solid fa-cash-register me-2"></i>Finalizar
                                    Venta</h5>
                                <button type="button" class="btn-close btn-close-white"
                                    data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="row">
                                    <div class="col-md-5 border-end">
                                        <h6 class="text-muted fw-bold">RESUMEN</h6>
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="text-muted small">Subtotal:</span>
                                            <span id="modalSubtotalTexto" class="fw-bold">$0.00</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2 text-danger">
                                            <span class="small fw-bold">Descuento Global:</span>
                                            <span id="modalDescuentoTexto" class="fw-bold">-$0.00</span>
                                        </div>
                                        <h2 class="fw-bold text-body mb-3" id="modalTotalCobroTexto">$0.00</h2>
                                        <input type="hidden" id="modalTotalCobroValor">

                                        <div class="mb-4 bg-body-tertiary p-2 rounded border border-warning-subtle">
                                            <label class="form-label fw-bold small mb-1"><i
                                                    class="fa-solid fa-tag text-warning me-1"></i>Aplicar Descuento a la
                                                venta (%)</label>
                                            <div class="input-group input-group-sm">
                                                <input type="number" id="inputDescuentoPorcentaje" class="form-control"
                                                    placeholder="Ej: 10" min="0" max="99">
                                                <span class="input-group-text bg-warning text-dark fw-bold">% OFF</span>
                                                <button class="btn btn-warning fw-bold text-dark ms-1" type="button"
                                                    onclick="aplicarDescuentoPorcentaje()">Aplicar</button>
                                            </div>
                                        </div>
                                        <div class="mb-4">
                                            <label class="form-label fw-bold">Cliente</label>
                                            <div class="input-group input-group-sm">
                                                <input type="text" id="buscadorCliente" class="form-control"
                                                    placeholder="Buscar cliente...">

                                                <button type="button" class="btn btn-primary"
                                                    onclick="crearClienteRapido()"><i
                                                        class="fa-solid fa-plus"></i></button>

                                            </div>
                                            <ul id="listaResultadosClientes"
                                                class="list-group position-absolute w-auto shadow-sm"
                                                style="z-index: 1050; display: none;"></ul>
                                            <input type="hidden" id="idClienteSeleccionado" value="1">
                                            <div id="divClienteSeleccionado"
                                                class="mt-2 p-2 bg-success text-white shadow-sm rounded d-none d-flex justify-content-between align-items-center">
                                                <span class="small fw-bold"><i
                                                        class="fa-solid fa-user-check me-1"></i><span
                                                        id="textoNombreCliente"></span></span>
                                                <button type="button" class="btn-close btn-close-white"
                                                    style="font-size: 0.5rem;" onclick="limpiarCliente()"></button>
                                            </div>
                                        </div>
                                        <div class="p-3 bg-body-tertiary rounded border">
                                            <h6 class="fw-bold mb-1">Estado del Pago</h6>
                                            <div class="d-flex justify-content-between">
                                                <span>Restante:</span>
                                                <span class="fw-bold text-danger" id="textoMontoRestante">$0.00</span>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span>Vuelto:</span>
                                                <span class="fw-bold text-success" id="textoVuelto">$0.00</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-7">
                                        <h6 class="text-muted fw-bold">REGISTRAR PAGOS</h6>
                                        <div class="input-group mb-3">
                                            <select id="selectMetodoPago" class="form-select">
                                                <option value="Efectivo">💵 Efectivo</option>
                                                <option value="Transferencia / QR">📱 Transferencia / QR</option>
                                                <option value="Tarjeta de Débito">💳 Débito</option>
                                                <option value="Tarjeta de Crédito">💳 Crédito</option>
                                            </select>
                                            <input type="text" id="montoIngresarPago"
                                                class="form-control w-25 input-precio" placeholder="Monto">

                                            <button type="button" class="btn btn-primary fw-bold"
                                                onclick="agregarPagoALista()"><i class="fa-solid fa-plus"></i></button>

                                        </div>
                                        <div class="table-responsive" style="max-height: 200px;">
                                            <table class="table table-sm table-hover border">
                                                <thead class="table-group-divider">
                                                    <tr>
                                                        <th>Método</th>
                                                        <th class="text-end">Monto</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tablaPagosAgregados"></tbody>
                                            </table>
                                        </div>

                                        <button type="button" id="btnConfirmarVentaFinal"
                                            class="btn btn-primary btn-lg w-100 fw-bold mt-3" disabled
                                            onclick="procesarCobroFinal()">
                                            <i class="fa-solid fa-check-circle me-2"></i>CONFIRMAR VENTA
                                        </button>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="modalVerTicket" data-bs-backdrop="static" aria-hidden="true"
                    data-bs-focus="false">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content shadow-lg border-0">
                            <div class="modal-header bg-dark text-white py-2">
                                <h6 class="modal-title m-0"><i class="fa-solid fa-receipt me-2"></i>Comprobante de Venta
                                </h6>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                    onclick="location.reload()"></button>
                            </div>
                            <div class="modal-body bg-light p-0" id="zonaImpresionTicket"
                                style="font-family: 'Courier New', Courier, monospace; font-size: 13px; color: black;">
                            </div>
                            <div class="modal-footer d-flex justify-content-between py-2">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal"
                                    onclick="location.reload()">Cerrar</button>
                                <div>
                                    <button type="button" class="btn btn-info btn-sm fw-bold text-white me-1"
                                        onclick="enviarTicketPorEmail()"><i
                                            class="fa-solid fa-envelope me-1"></i>Email</button>
                                    <button type="button" class="btn btn-primary btn-sm fw-bold"
                                        onclick="imprimirTicketFisico()"><i
                                            class="fa-solid fa-print me-2"></i>Imprimir</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="modalDetalleProducto" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow-lg">
                            <div class="modal-header bg-secondary text-white">
                                <h5 class="modal-title"><i class="fa-solid fa-circle-info me-2"></i>Detalles del
                                    Producto</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                            </div>
                            <div class="modal-body text-center p-4">
                                <img id="detalleImagen" src="" alt="Producto" class="img-fluid rounded mb-3 shadow-sm"
                                    style="max-height: 250px; object-fit: contain;">
                                <h4 id="detalleNombre" class="fw-bold mb-1 text-body">Nombre</h4>
                                <p class="text-muted small mb-3">SKU: <span id="detalleSku" class="fw-bold"></span></p>
                                <div
                                    class="bg-body-tertiary p-3 rounded text-start shadow-sm border border-secondary-subtle">
                                    <h6 class="fw-bold border-bottom pb-2 mb-2"><i
                                            class="fa-solid fa-align-left me-2 text-primary"></i>Descripción</h6>
                                    <p id="detalleDescripcion" class="mb-0 text-body"
                                        style="white-space: pre-wrap; font-size: 0.95rem;">Descripción...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

                <script src="/assets/js/carrito.js"></script>

                <script>
                    const temaActual = localStorage.getItem('temaTienda');
                    if (temaActual === 'dark') document.documentElement.setAttribute('data-bs-theme', 'dark');

                    function verDetalleProducto(nombre, sku, descripcion, imagen) {
                        document.getElementById('detalleNombre').innerText = nombre;
                        document.getElementById('detalleSku').innerText = sku;
                        document.getElementById('detalleImagen').src = imagen;
                        document.getElementById('detalleDescripcion').innerText = descripcion ? descripcion : "No hay especificaciones adicionales para este producto.";
                        new bootstrap.Modal(document.getElementById('modalDetalleProducto')).show();
                    }
                </script>
</body>

</html>