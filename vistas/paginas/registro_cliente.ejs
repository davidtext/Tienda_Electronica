<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Cuenta - Tienda Online</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="bg-dark text-light d-flex justify-content-center align-items-center min-vh-100 py-5">

    <div class="card bg-secondary p-4 shadow-lg border-0" style="width: 30rem; border-radius: 12px;">
        <div class="text-center mb-4">
            <h4 class="fw-bold m-0 text-white">Completá tus datos</h4>
            <p class="text-light opacity-75 small mt-1">Solo te tomará un minuto.</p>
        </div>
        
        <form id="formRegistroCliente">
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold small mb-1">Nombre</label>
                    <input type="text" class="form-control form-control-sm" name="nombre" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small mb-1">Apellido</label>
                    <input type="text" class="form-control form-control-sm" name="apellido" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold small mb-1">DNI / CUIL</label>
                <input type="number" class="form-control form-control-sm" name="dni" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold small mb-1">Correo Electrónico</label>
                <input type="email" class="form-control form-control-sm" name="email" placeholder="Te enviaremos un código aquí" required>
            </div>

            <div class="row g-2 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold small mb-1">Contraseña</label>
                    <input type="password" class="form-control form-control-sm" name="password" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small mb-1">Confirmar Contraseña</label>
                    <input type="password" class="form-control form-control-sm" name="password_conf" required>
                </div>
            </div>
            
            <button type="button" class="btn btn-primary w-100 fw-bold shadow-sm mb-3" onclick="registrarCliente()">
                Registrarme y Recibir Código
            </button>

            <div class="text-center border-top border-secondary pt-3 mt-2">
                <span class="text-light opacity-75 small">¿Ya tenés una cuenta?</span>
                <a href="/tienda/login" class="text-info fw-bold text-decoration-none ms-1">Ingresá acá</a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function registrarCliente() {
            // Empaquetamos los datos que escribió el cliente
            const form = document.getElementById('formRegistroCliente');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            // Mostramos un "Cargando" porque enviar un correo demora 2 segunditos
            Swal.fire({ 
                title: 'Procesando...', 
                text: 'Creando cuenta y enviando correo de seguridad', 
                allowOutsideClick: false, 
                didOpen: () => { Swal.showLoading() } 
            });

            // Enviamos los datos a la API de Node.js
            fetch('/api/tienda/registro', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(respuesta => {
                if(respuesta.status === 'success') {
                    Swal.fire('¡Éxito!', respuesta.message, 'success').then(() => {
                        // Lo mandamos a la pantalla para que meta los 6 dígitos
                        window.location.href = '/tienda/verificar'; 
                    });
                } else {
                    Swal.fire('Error', respuesta.message, 'error');
                }
            })
            .catch(error => {
                console.error(error);
                Swal.fire('Error', 'No se pudo conectar con el servidor', 'error');
            });
        }
    </script>
</body>
</html>