<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Usuarios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body>

    <%- include('../componentes/navbar') %>

        <div class="container-fluid mt-4 px-4">
            <h2 class="mb-4 text-primary fw-bold">Gestión de Personal</h2>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">Nuevo Empleado</h5>
                        </div>
                        <div class="card-body">
                            <form id="formNuevoEmpleado" novalidate>
                                <div class="mb-3">
                                    <label class="form-label text-muted fw-bold">Nombre *</label>
                                    <input type="text" id="nuevo_nombre" class="form-control">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-muted fw-bold">Apellido *</label>
                                    <input type="text" id="nuevo_apellido" class="form-control">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-muted fw-bold">DNI *</label>
                                    <input type="text" id="nuevo_dni" class="form-control">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-muted fw-bold">Email (Usuario) *</label>
                                    <input type="email" id="nuevo_email" class="form-control">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label text-muted fw-bold">Rol *</label>
                                    <select id="nuevo_rol" class="form-select">
                                        <option value="" disabled selected>Seleccione...</option>
                                        <option value="1">Administrador</option>
                                        <option value="2">Empleado (Mostrador)</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 fw-bold">Guardar Empleado</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">

                            <form action="/usuarios" method="GET"
                                class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="card-title text-secondary m-0">Personal Registrado</h5>
                                <div class="input-group w-50">
                                    <input type="text" name="busqueda" class="form-control" placeholder="Buscar..."
                                        value="<%= typeof busquedaActual !== 'undefined' ? busquedaActual : '' %>">
                                    <button type="submit" class="btn btn-primary"><i
                                            class="fa-solid fa-search"></i></button>
                                    <% if (typeof busquedaActual !=='undefined' && busquedaActual) { %>
                                        <a href="/usuarios" class="btn btn-outline-danger"><i
                                                class="fa-solid fa-times"></i></a>
                                        <% } %>
                                </div>
                            </form>

                            <div class="table-responsive">
                                <table class="table table-hover table-bordered align-middle">
                                    <thead class="table">
                                        <tr>
                                            <th>ID</th>
                                            <th>Nombre Completo</th>
                                            <th>Email (Usuario)</th>
                                            <th>Rol</th>
                                            <th class="text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (usuarios.length> 0) { %>
                                            <% usuarios.forEach(function(u) { %>
                                                <tr>
                                                    <td class="fw-bold text-muted">#<%= u.id %>
                                                    </td>
                                                    <td class="fw-bold">
                                                        <%= u.apellido %>, <%= u.nombre %> <br><small
                                                                    class="text-muted fw-normal">DNI: <%= u.dni %>
                                                                        </small>
                                                    </td>
                                                    <td>
                                                        <%= u.email_acceso %>
                                                    </td>
                                                    <td>
                                                        <% if (u.rol_id===1 ) { %>
                                                            <span class="badge bg-danger">
                                                                <%= u.rol %>
                                                            </span>
                                                            <% } else { %>
                                                                <span class="badge bg-success">
                                                                    <%= u.rol %>
                                                                </span>
                                                                <% } %>
                                                    </td>
                                                    <td class="text-center">
                                                        <button class="btn btn-sm btn-outline-primary"
                                                            onclick="abrirModalEditar('<%= u.id %>', '<%= u.empleado_id %>', '<%= u.nombre %>', '<%= u.apellido %>', '<%= u.dni %>', '<%= u.email_acceso %>', '<%= u.rol_id %>')">
                                                            <i class="fa-solid fa-pen"></i>
                                                        </button>
                                                        <% if (u.id !==1) { %>
                                                            <button class="btn btn-sm btn-outline-warning ms-1"
                                                                onclick="reiniciarUsuario(<%= u.id %>, '<%= u.email_acceso %>')">
                                                                <i class="fa-solid fa-power-off"></i>
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-danger ms-1"
                                                                onclick="borrarUsuario(<%= u.id %>)">
                                                                <i class="fa-solid fa-trash"></i>
                                                            </button>
                                                            <% } else { %>
                                                                <span class="badge bg-secondary ms-1"></span>
                                                                <% } %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5" class="text-center text-muted py-4">No hay
                                                                empleados.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>

                            <% if (typeof totalPaginas !=='undefined' && totalPaginas> 1) { %>
                                <nav class="mt-3">
                                    <ul class="pagination justify-content-center shadow-sm mb-0">
                                        <li class="page-item <%= paginaActual === 1 ? 'disabled' : '' %>">
                                            <a class="page-link"
                                                href="<%= urlBase %>pagina=<%= paginaActual - 1 %>">Anterior</a>
                                        </li>
                                        <% for (let i=1; i <=totalPaginas; i++) { %>
                                            <li class="page-item <%= paginaActual === i ? 'active' : '' %>">
                                                <a class="page-link fw-bold" href="<%= urlBase %>pagina=<%= i %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                            <% } %>
                                                <li
                                                    class="page-item <%= paginaActual === totalPaginas ? 'disabled' : '' %>">
                                                    <a class="page-link"
                                                        href="<%= urlBase %>pagina=<%= paginaActual + 1 %>">Siguiente</a>
                                                </li>
                                    </ul>
                                </nav>
                                <% } %>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalEditarUsuario" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title"><i class="fa-solid fa-user-pen me-2"></i>Editar Empleado</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="formEditarUsuario" novalidate>
                            <input type="hidden" id="edit_id">
                            <input type="hidden" id="edit_empleado_id">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Nombre *</label>
                                <input type="text" id="edit_nombre" class="form-control">
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Apellido *</label>
                                <input type="text" id="edit_apellido" class="form-control">
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">DNI *</label>
                                <input type="text" id="edit_dni" class="form-control">
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Email de Acceso *</label>
                                <input type="email" id="edit_email" class="form-control">
                                <small class="text-danger fw-bold">¡Atención! Si cambias esto, el usuario deberá iniciar
                                    sesión con este nuevo correo.</small>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Rol *</label>
                                <select id="edit_rol" class="form-select">
                                    <option value="1">Administrador</option>
                                    <option value="2">Empleado</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 fw-bold">Guardar Cambios</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="/assets/js/usuarios_validacion.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>