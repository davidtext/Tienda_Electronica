<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Pedidos Web</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body class="bg-body-tertiary">

    <%- include('../componentes/navbar.ejs') %>

    <div class="container-fluid mt-4 mb-5 px-4">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h3 class="fw-bold m-0"><i class="fa-solid fa-truck-fast text-primary me-2"></i>Despacho de Órdenes Web</h3>

            <form action="/pedidos-web" method="GET" class="d-flex gap-2">
                <input type="text" class="form-control form-control-sm border-secondary shadow-sm" name="busqueda"
                    placeholder="Buscar por Orden o Cliente..." value="<%= busquedaActual %>" style="width: 250px;">

                <select name="estado" class="form-select form-select-sm border-secondary shadow-sm" style="width: 200px;">
                    <option value="">🏷️ Todos los estados</option>
                    <option value="Pendiente de Despacho" <%= estadoActual === 'Pendiente de Despacho' ? 'selected' : '' %>>📦 Por Preparar</option>
                    <option value="Enviado por Correo" <%= estadoActual === 'Enviado por Correo' ? 'selected' : '' %>>🚚 Despachado (Envío)</option>
                    <option value="Retira en Sucursal" <%= estadoActual === 'Retira en Sucursal' ? 'selected' : '' %>>🏪 Listo p/ Retirar</option>
                    <option value="Entregado" <%= estadoActual === 'Entregado' ? 'selected' : '' %>>✅ Entregado</option>
                    <option value="Visita Fallida" <%= estadoActual === 'Visita Fallida' ? 'selected' : '' %>>⚠️ Visita Fallida</option>
                    <option value="Cancelado por Cliente" <%= estadoActual === 'Cancelado por Cliente' ? 'selected' : '' %>>❌ Cancelados</option>
                </select>

                <button type="submit" class="btn btn-primary btn-sm fw-bold shadow-sm"><i class="fa-solid fa-magnifying-glass"></i> Buscar</button>
                <a href="/pedidos-web" class="btn btn-outline-secondary btn-sm shadow-sm" title="Limpiar"><i class="fa-solid fa-eraser"></i></a>
            </form>
        </div>

        <div class="card shadow-sm border-secondary-subtle">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0 text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>Orden</th>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Entrega</th>
                                <th>Pago Ref</th>
                                <th>Total</th>
                                <th>Estado Envío</th>
                                <th>Despacho</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pedidos && pedidos.length > 0) { %>
                                <% pedidos.forEach(pedido => { %>
                                    <tr>
                                        <td class="fw-bold">
                                            #<%= pedido.id %><br>
                                            <button class="btn btn-sm btn-outline-primary mt-1" onclick="verProductos(<%= pedido.id %>)"><i class="fa-solid fa-box-open"></i> Ver</button>
                                        </td>
                                        <td class="small"><%= new Date(pedido.fecha_hora).toLocaleDateString('es-AR') %></td>
                                        <td class="text-start">
                                            <span class="fw-bold d-block"><%= pedido.cliente_nombre %> <%= pedido.cliente_apellido %></span>
                                            <small class="text-muted"><i class="fa-solid fa-phone me-1"></i><%= pedido.cliente_telefono || 'Sin tel' %></small>
                                        </td>
                                        <td class="text-start small">
                                            <% if (pedido.calle) { %>
                                                <span class="badge bg-info text-dark mb-1">Domicilio</span><br>
                                                <%= pedido.calle %> <%= pedido.numero %>, <%= pedido.ciudad %>
                                            <% } else { %>
                                                <span class="badge bg-secondary mb-1">Retiro Local</span><br>
                                                <span class="text-muted">Mostrador</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="fw-bold text-primary d-block small"><%= pedido.metodo_pago %></span>
                                            <small class="text-muted" style="font-size: 0.7rem;"><%= pedido.id_pago_mercadopago || 'N/A' %></small>
                                        </td>
                                        <td class="fw-bold text-success">$<%= Number(pedido.total_venta).toLocaleString('es-AR') %></td>
                                        <td>
                                            <% if (pedido.estado_envio === 'Pendiente de Despacho') { %>
                                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-box me-1"></i> Por Preparar</span>
                                            <% } else if (pedido.estado_envio === 'Retira en Sucursal') { %>
                                                <span class="badge bg-primary"><i class="fa-solid fa-store me-1"></i> Listo p/ Retiro</span>
                                            <% } else if (pedido.estado_envio === 'Cancelado por Cliente') { %>
                                                <span class="badge bg-danger"><i class="fa-solid fa-ban me-1"></i> Cancelado</span>
                                            <% } else { %>
                                                <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i> <%= pedido.estado_envio %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm border-secondary shadow-sm" style="min-width: 150px;" onchange="cambiarEstadoEnvio(<%= pedido.id %>, this)">
                                                <option value="" disabled selected>Cambiar estado...</option>
                                                <option value="Pendiente de Despacho">📦 Por Preparar</option>
                                                
                                                <% if (pedido.calle) { %>
                                                    <option value="Enviado por Correo">🚚 Despachado (En camino)</option>
                                                    <option value="Visita Fallida">⚠️ Visita Fallida (No estaba)</option>
                                                <% } else { %>
                                                    <option value="Retira en Sucursal">🏪 Listo para Retirar</option>
                                                <% } %>
                                                
                                                <option value="Entregado">✅ Entregado</option>
                                            </select>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted fw-bold">No se encontraron pedidos con esos filtros.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <% if (totalPaginas > 1) { %>
                <div class="card-footer bg-body d-flex justify-content-center pt-3 pb-2 border-top-0">
                    <nav>
                        <ul class="pagination pagination-sm m-0 shadow-sm">
                            <li class="page-item <%= paginaActual === 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= urlBase %>pagina=<%= paginaActual - 1 %>">Anterior</a>
                            </li>
                            <% for(let i = 1; i <= totalPaginas; i++) { %>
                                <li class="page-item <%= paginaActual === i ? 'active' : '' %>">
                                    <a class="page-link" href="<%= urlBase %>pagina=<%= i %>"><%= i %></a>
                                </li>
                            <% } %>
                            <li class="page-item <%= paginaActual === totalPaginas ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= urlBase %>pagina=<%= paginaActual + 1 %>">Siguiente</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            <% } %>
        </div>
    </div>

    <div class="modal fade" id="modalDetalleProductos" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-secondary-subtle">
                <div class="modal-header bg-body border-bottom">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-box text-primary me-2"></i>Ficha del Pedido Web</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div id="listaProductosModal"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const temaActual = localStorage.getItem('tema');
        if (temaActual === 'dark') document.documentElement.setAttribute('data-bs-theme', 'dark');

        // ==========================================
        // LÓGICA INTERACTIVA DE CAMBIO DE ESTADOS
        // ==========================================
        function cambiarEstadoEnvio(idVenta, selectElement) {
            const nuevoEstado = selectElement.value;

            // INTERCEPCIÓN DIGITAL: Si selecciona entregado pedimos los datos obligatorios
            if (nuevoEstado === 'Entregado') {
                Swal.fire({
                    title: 'Confirmar Entrega',
                    html: `
                        <p class="small text-muted mb-3">Ingresa los datos de la persona que recibe el paquete (o el cliente en mostrador):</p>
                        <input id="swal-nombre" class="swal2-input m-0 mb-2 w-75" placeholder="Nombre completo" required>
                        <input id="swal-dni" class="swal2-input m-0 w-75" placeholder="Nro de DNI" type="number" required>
                    `,
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-check"></i> Registrar Entrega',
                    cancelButtonText: 'Cancelar',
                    preConfirm: () => {
                        const nombre = document.getElementById('swal-nombre').value;
                        const dni = document.getElementById('swal-dni').value;
                        if (!nombre || !dni) {
                            Swal.showValidationMessage('El Nombre y el DNI son obligatorios para cerrar la orden.');
                        }
                        return { nombre: nombre, dni: dni };
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Enviamos los datos con los nombres exactos que el controlador espera
                        ejecutarActualizacion(idVenta, nuevoEstado, result.value.nombre, result.value.dni);
                    } else {
                        // Si cancela, devolvemos el selector a su estado previo
                        window.location.reload();
                    }
                });
            } else {
                // Si es cualquier otro estado, viaja directo sin pasar por el formulario de DNI
                ejecutarActualizacion(idVenta, nuevoEstado, null, null);
            }
        }

        function ejecutarActualizacion(idVenta, nuevoEstado, receptorNombre, receptorDni) {
            fetch('/api/pedidos/actualizar-envio', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    id_venta: idVenta, 
                    nuevo_estado: nuevoEstado,
                    receptor_nombre: receptorNombre, // <-- Esto calza justo con tu req.body
                    receptor_dni: receptorDni        // <-- Esto calza justo con tu req.body
                })
            })
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') {
                    Swal.fire({ title: '¡Actualizado!', text: data.message, icon: 'success', timer: 1500, showConfirmButton: false })
                    .then(() => window.location.reload());
                } else {
                    Swal.fire('Error', data.message, 'error').then(() => window.location.reload());
                }
            });
        }

        // ==========================================
        // VISTA DE FICHA EN MODAL (WHASTAPP Y MAPS)
        // ==========================================
        function verProductos(idVenta) {
            const modal = new bootstrap.Modal(document.getElementById('modalDetalleProductos'));
            const lista = document.getElementById('listaProductosModal');

            lista.innerHTML = '<div class="text-center text-muted py-4"><i class="fa-solid fa-spinner fa-spin me-2"></i> Buscando información de la orden...</div>';
            modal.show();

            fetch(`/api/pedidos/${idVenta}/detalles`)
                .then(res => res.json())
                .then(data => {
                    if (data.status === 'success') {
                        const cab = data.cabecera;
                        const direccionCompleta = `${cab.calle} ${cab.numero}, ${cab.ciudad}, ${cab.provincia}`;
                        const linkGoogleMaps = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(direccionCompleta)}`;

                        let infoHtml = `
                        <div class="bg-body-tertiary p-3 border-bottom">
                            <div class="row small">
                                <div class="col-sm-6 mb-2 mb-sm-0">
                                    <span class="text-muted fw-bold d-block mb-1"><i class="fa-solid fa-user me-1"></i> Datos del Cliente:</span>
                                    <strong class="text-body fs-6">${cab.nombre} ${cab.apellido}</strong><br>
                                    <i class="fa-solid fa-id-card text-muted me-1"></i> DNI: ${cab.dni_cuil}<br>
                                    <i class="fa-brands fa-whatsapp text-muted me-1"></i> Tel: <a href="https://api.whatsapp.com/send?phone=${cab.telefono}" target="_blank" class="text-decoration-none text-success fw-bold">${cab.telefono || 'Sin teléfono'}</a><br>
                                    <i class="fa-solid fa-envelope text-muted me-1"></i> Email: ${cab.email}
                                </div>
                                <div class="col-sm-6">
                                    <span class="text-muted fw-bold d-block mb-1"><i class="fa-solid fa-truck me-1"></i> Logística y Pago:</span>
                                    ${cab.calle
                                    ? `<strong class="text-info"><i class="fa-solid fa-truck"></i> Envío Domicilio</strong><br>
                                       <a href="${linkGoogleMaps}" target="_blank" class="text-decoration-none text-body fw-semibold" title="Abrir en Google Maps">
                                           <i class="fa-solid fa-map-pin text-danger"></i> ${cab.calle} ${cab.numero}, ${cab.ciudad}
                                       </a>`
                                    : `<strong class="text-secondary"><i class="fa-solid fa-store"></i> Retira en Local</strong><br>Mostrador Sucursal`}
                                    <div class="mt-2 pt-2 border-top d-flex justify-content-between align-items-center">
                                        <strong class="${cab.estado === 'Pendiente' ? 'text-warning' : 'text-success'}"><i class="fa-solid fa-money-bill me-1"></i> ${cab.metodo_pago} ($${Number(cab.total_venta).toLocaleString('es-AR')})</strong>
                                        ${cab.calle ? `<a href="/pedidos-web/${idVenta}/remito" target="_blank" class="btn btn-sm btn-dark fw-bold shadow-sm"><i class="fa-solid fa-print me-1"></i> Imprimir Etiqueta</a>` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;

                        let productosHtml = '<ul class="list-group list-group-flush">';
                        data.detalles.forEach(item => {
                            productosHtml += `
                            <li class="list-group-item p-3 d-flex align-items-center bg-body">
                                <img src="${item.imagen}" class="rounded border me-3" style="width: 50px; height: 50px; object-fit: contain;">
                                <div class="flex-grow-1">
                                    <h6 class="m-0 fw-semibold text-body">${item.nombre}</h6>
                                    <small class="text-muted">SKU: ${item.sku}</small><br>
                                    <span class="badge bg-secondary mt-1">${item.cantidad} unidades solicitadas</span>
                                </div>
                            </li>`;
                        });
                        productosHtml += '</ul>';

                        lista.innerHTML = infoHtml + productosHtml;
                    } else {
                        lista.innerHTML = `<div class="text-danger text-center fw-bold py-3">${data.message}</div>`;
                    }
                })
                .catch(() => lista.innerHTML = `<div class="text-danger text-center fw-bold py-3">Error de conexión.</div>`);
        }
    </script>
</body>

</html>