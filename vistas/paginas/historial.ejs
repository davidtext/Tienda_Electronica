<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historial de Ventas y Caja</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body>

    <%- include('../componentes/navbar') %>

        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold"><i class="fa-solid fa-cash-register me-2"></i>Historial de Ventas</h3>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="text-muted fw-bold mb-0">Cierre de Caja (Ventas de Hoy)</h6>
                <% if (cajaHoy.estado_caja==='Cerrada' ) { %>
                    <button class="btn btn-warning fw-bold shadow-sm text-dark" onclick="abrirCaja()">
                        <i class="fa-solid fa-lock-open me-2"></i>Abrir Caja del Día
                    </button>
                    <% } else { %>
                        <span class="badge bg-success fs-6"><i class="fa-solid fa-check-circle me-1"></i> Caja
                            Abierta</span>
                        <% } %>
            </div>

            <% if (cajaHoy.estado_caja==='Cerrada' ) { %>
                <div class="alert alert-warning fw-bold text-center py-4 mb-4">
                    <i class="fa-solid fa-triangle-exclamation fs-3 mb-2 d-block"></i>
                    La caja del día aún no está abierta. Registra tu fondo inicial para comenzar.
                </div>
                <% } else { %>
                    <div class="row mb-4 g-3">
                        <div class="col-md-3">
                            <div class="card border-warning shadow-sm h-100 bg-body-tertiary">
                                <div class="card-body d-flex align-items-center">
                                    <div>
                                        <p class="text-muted mb-0 fw-bold small">Fondo Inicial</p>
                                        <h4 class="text-warning fw-bold mb-0">$<%=
                                                Number(cajaHoy.monto_inicial).toLocaleString('es-AR') %>
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-success shadow-sm h-100 bg-body-tertiary">
                                <div class="card-body d-flex align-items-center">
                                    <div>
                                        <p class="text-muted mb-0 fw-bold small">Efectivo (+Fondo)</p>
                                        <h4 class="text-success fw-bold mb-0">$<%=
                                                Number(cajaHoy.total_efectivo).toLocaleString('es-AR') %>
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-primary shadow-sm h-100 bg-body-tertiary">
                                <div class="card-body d-flex align-items-center">
                                    <div>
                                        <p class="text-muted mb-0 fw-bold small">Digital</p>
                                        <h4 class="text-primary fw-bold mb-0">$<%=
                                                Number(cajaHoy.total_digital).toLocaleString('es-AR') %>
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-dark shadow-sm h-100 bg-dark text-white">
                                <div class="card-body d-flex align-items-center">
                                    <div>
                                        <p class="text-light mb-0 fw-bold small">Total en Caja Hoy</p>
                                        <h4 class="fw-bold mb-0 text-white">$<%=
                                                Number(cajaHoy.total_general).toLocaleString('es-AR') %>
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>

                        <form method="GET" action=""
                            class="row g-2 mb-3 align-items-center bg-body-tertiary p-3 rounded shadow-sm border">
                            <div class="col-md-5">
                                <label class="form-label text-muted fw-bold small mb-1">Buscar (Ticket, Cajero o
                                    Cliente)</label>
                                <input type="text" name="busqueda" class="form-control" placeholder="Ej: 77, David..."
                                    value="<%= typeof busquedaActual !== 'undefined' ? busquedaActual : '' %>">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-muted fw-bold small mb-1">Filtrar por Fecha</label>
                                <input type="date" name="fecha" class="form-control"
                                    value="<%= typeof fechaActual !== 'undefined' ? fechaActual : '' %>">
                            </div>
                            <div class="col-md-4 d-flex align-items-end mt-4">
                                <button type="submit" class="btn btn-primary fw-bold w-50 me-2"><i
                                        class="fa-solid fa-search me-1"></i> Buscar</button>

                                <% if ((typeof busquedaActual !=='undefined' && busquedaActual) || (typeof fechaActual
                                    !=='undefined' && fechaActual)) { %>
                                    <a href="/historial" class="btn btn-outline-danger w-50" title="Limpiar Filtros">
                                        <i class="fa-solid fa-eraser"></i> Limpiar
                                    </a>
                                    <% } %>
                            </div>
                        </form>

                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-dark">
                                            <tr>
                                                <th class="ps-3">Ticket N°</th>
                                                <th>Fecha y Hora</th>
                                                <th>Cajero</th>
                                                <th>Método</th>
                                                <th>Total</th>
                                                <th>Estado</th>
                                                <th class="text-center pe-3">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (ventas && ventas.length> 0) { %>
                                                <% ventas.forEach(v=> { %>
                                                    <tr class="<%= v.estado === 'Anulada' ? 'table-danger' : '' %>">
                                                        <td class="ps-3 fw-bold">#<%= v.id %>
                                                        </td>
                                                        <td>
                                                            <%= new Date(v.fecha_hora).toLocaleString('es-AR') %>
                                                        </td>
                                                        <td>
                                                            <%= v.nombre %>
                                                                <%= v.apellido %>
                                                        </td>
                                                        <td>
                                                            <% if (v.metodo_pago==='Efectivo' ) { %>
                                                                <i
                                                                    class="fa-solid fa-money-bill-wave text-success me-1"></i>
                                                                Efectivo
                                                                <% } else if (v.metodo_pago.includes('Tarjeta')) { %>
                                                                    <i
                                                                        class="fa-solid fa-credit-card text-primary me-1"></i>
                                                                    Tarjeta
                                                                    <% } else { %>
                                                                        <i
                                                                            class="fa-solid fa-mobile-screen text-info me-1"></i>
                                                                        Transf/QR
                                                                        <% } %>
                                                        </td>
                                                        <td class="fw-bold">$<%=
                                                                Number(v.total_venta).toLocaleString('es-AR') %>
                                                        </td>
                                                        <td>
                                                            <% if (v.estado==='Completada' ) { %>
                                                                <span class="badge bg-success">Completada</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Anulada</span>
                                                                    <% } %>
                                                        </td>
                                                        <td class="text-center pe-3">
                                                            <button class="btn btn-sm btn-outline-secondary"
                                                                onclick="reimprimirTicket(<%= v.id %>)"
                                                                title="Ver Ticket">
                                                                <i class="fa-solid fa-print"></i>
                                                            </button>

                                                            <% if (v.estado==='Completada' ) { %>
                                                                <button class="btn btn-sm btn-outline-danger ms-1"
                                                                    onclick="confirmarAnulacion(<%= v.id %>)"
                                                                    title="Anular Venta">
                                                                    <i class="fa-solid fa-ban"></i>
                                                                </button>
                                                                <% } %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="7" class="text-center py-4 text-muted">
                                                                    <i class="fa-solid fa-inbox fa-2x mb-2"></i><br>
                                                                    No hay ventas registradas aún.
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
        </div>

        <% if (typeof totalPaginas !=='undefined' && totalPaginas> 1) { %>
            <nav class="mt-4 mb-5">
                <ul class="pagination justify-content-center shadow-sm">
                    <li class="page-item <%= paginaActual === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="<%= urlBase %>pagina=<%= paginaActual - 1 %>">Anterior</a>
                    </li>

                    <% for(let i=1; i <=totalPaginas; i++) { %>
                        <li class="page-item <%= paginaActual === i ? 'active' : '' %>">
                            <a class="page-link fw-bold" href="<%= urlBase %>pagina=<%= i %>">
                                <%= i %>
                            </a>
                        </li>
                        <% } %>

                            <li class="page-item <%= paginaActual === totalPaginas ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= urlBase %>pagina=<%= paginaActual + 1 %>">Siguiente</a>
                            </li>
                </ul>
            </nav>
            <% } %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

                <script>
                    // ==========================================
                    // 1. Función para abrir la caja (Fondo Inicial)
                    // ==========================================
                    function abrirCaja() {
                        Swal.fire({
                            title: 'Abrir Caja Diaria',
                            text: 'Ingresa el monto del fondo inicial (cambio en billetes):',
                            input: 'number',
                            inputAttributes: { min: 0, step: 0.01 },
                            inputValue: 0,
                            showCancelButton: true,
                            confirmButtonText: 'Abrir Caja',
                            cancelButtonText: 'Cancelar'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                fetch('/caja/abrir', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ monto_inicial: parseFloat(result.value) })
                                })
                                    .then(res => res.json())
                                    .then(data => {
                                        if (data.status === 'success') {
                                            Swal.fire('¡Caja Abierta!', data.message, 'success').then(() => location.reload());
                                        } else {
                                            Swal.fire('Error', data.message, 'error');
                                        }
                                    });
                            }
                        });
                    }

                    // ==========================================
                    // 2. Función para abrir la pestaña del ticket
                    // ==========================================
                    function reimprimirTicket(id) {
                        window.open('/ventas/ticket/' + id, 'Ticket', 'width=400,height=600');
                    }

                    // ==========================================
                    // 3. Función del BOTÓN DEL PÁNICO (Anular Venta con RMA)
                    // ==========================================
                    function confirmarAnulacion(idVenta) {
                        Swal.fire({
                            title: 'Anular Venta N° ' + idVenta,
                            html: `
                                <p class="text-muted mb-3" style="font-size: 0.95rem;">Selecciona el motivo para gestionar correctamente el inventario:</p>
                                <select id="motivoAnulacion" class="form-select border-danger shadow-sm fw-bold text-dark">
                                    <option value="normal">🔄 Cambio Normal / Arrepentimiento (Vuelve a Stock Activo)</option>
                                    <option value="falla">⚠️ Falla de Fábrica (Se envía a Stock Defectuoso / Garantía)</option>
                                    <option value="dano">📦 Daño físico en Envío (Se envía a Stock Defectuoso / Seguro)</option>
                                </select>
                            `,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#dc3545', // Rojo
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: 'Sí, Anular Venta',
                            cancelButtonText: 'Cancelar',
                            preConfirm: () => {
                                // Capturamos la opción elegida por el empleado
                                return document.getElementById('motivoAnulacion').value;
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                const motivoElegido = result.value;
                                Swal.fire({ title: 'Procesando devolución...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

                                // Enviamos la petición al servidor ADJUNTANDO EL MOTIVO
                                fetch('/ventas/anular/' + idVenta, {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ motivo: motivoElegido })
                                })
                                    .then(response => response.json())
                                    .then(data => {
                                        if (data.status === 'success') {
                                            Swal.fire('¡Anulada!', data.message, 'success').then(() => location.reload());
                                        } else {
                                            Swal.fire('Error', data.message, 'error');
                                        }
                                    })
                                    .catch(error => {
                                        console.error('Error:', error);
                                        Swal.fire('Error de conexión', 'No se pudo procesar la solicitud.', 'error');
                                    });
                            }
                        })
                    }
                </script>
</body>

</html>