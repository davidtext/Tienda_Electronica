<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reestablecer Contraseña - Tienda Online</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="bg-dark text-light d-flex justify-content-center align-items-center vh-100">

    <div class="card bg-secondary p-4 shadow-lg border-0" style="width: 25rem; border-radius: 12px;">
        <div class="text-center mb-4">
            <i class="fa-solid fa-key fs-1 text-success mb-2"></i>
            <h4 class="fw-bold m-0">Nueva Contraseña</h4>
            <p class="text-light opacity-75 small mt-1">Ingresá el código de 6 dígitos enviado a tu mail</p>
        </div>
        
        <form id="formReestablecer">
            <div class="mb-3">
                <label class="form-label fw-semibold">Código de Verificación</label>
                <input type="text" class="form-control text-center fw-bold fs-4 font-monospace" name="codigo" placeholder="000000" maxlength="6" required>
            </div>
            <div class="mb-2">
                <label class="form-label fw-semibold">Nueva Contraseña</label>
                <input type="password" class="form-control" name="password_nueva" placeholder="Mínimo 6 caracteres" required>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Confirmar Contraseña</label>
                <input type="password" class="form-control" name="password_conf" placeholder="Repetí tu contraseña" required>
            </div>
            
            <button type="button" class="btn btn-success w-100 fw-bold fs-6 shadow-sm mb-3" onclick="procesarCambio()">
                Cambiar Contraseña e Ingresar
            </button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function procesarCambio() {
            const form = document.getElementById('formReestablecer');
            if(!form.checkValidity()) return form.reportValidity();

            const data = Object.fromEntries(new FormData(form));

            if(data.password_nueva !== data.password_conf) {
                return Swal.fire('Error', 'Las contraseñas no coinciden.', 'warning');
            }

            Swal.fire({ title: 'Guardando nueva clave...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });

            fetch('/api/tienda/recuperar-cuenta/confirmar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(res => {
                if (res.status === 'success') {
                    Swal.fire('¡Éxito!', res.message, 'success').then(() => {
                        window.location.href = '/tienda/login';
                    });
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            })
            .catch(() => Swal.fire('Error', 'No se pudo conectar con el servidor', 'error'));
        }
    </script>
</body>
</html>