<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tienda Online - Tu E-commerce</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .card-producto {
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
            border-radius: 12px;
            overflow: hidden;
        }

        .card-producto:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15) !important;
        }

        .contenedor-imagen {
            height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #fff;
            padding: 15px;
        }

        .imagen-prod {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

        .badge-descuento {
            position: absolute;
            top: 10px;
            left: 10px;
            font-size: 0.85rem;
            padding: 5px 10px;
            border-radius: 20px;
            font-weight: bold;
        }

        /* ESTILOS DEL BOTÓN VOLVER ARRIBA */
        #btnVolverArriba {
            display: none;
            position: fixed;
            bottom: 110px;
            /* Para que no pise al carrito */
            right: 37px;
            z-index: 1040;
            border: none;
            outline: none;
            background-color: #fc4b08;
            /* Naranja rojizo estilo imagen */
            color: white;
            cursor: pointer;
            padding: 15px;
            border-radius: 50%;
            font-size: 18px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            transition: background-color 0.3s;
        }

        #btnVolverArriba:hover {
            background-color: #d93d04;
        }

        /* ESTILOS DEL FOOTER */
        .footer-social-icon {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            border-radius: 50%;
            color: white;
            text-decoration: none;
            margin: 0 5px;
            transition: all 0.3s;
        }

        .footer-social-icon:hover {
            background-color: white;
            color: #212529;
        }
    </style>
</head>

<body class="bg-body-tertiary d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg bg-body shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/tienda">🛒 Tienda Online</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <form class="d-flex mx-auto col-lg-6 my-2 my-lg-0" id="formBuscador" onsubmit="aplicarFiltros(event)">
                    <div class="input-group">
                        <input type="text" class="form-control" id="inputBusqueda"
                            placeholder="Buscar productos, marcas y más..." value="<%= filtrosActuales.busqueda %>">
                        <button class="btn btn-primary" type="submit"><i
                                class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                </form>

                <div class="navbar-nav align-items-center gap-3">
                    <button class="btn btn-outline-secondary border-0" id="btnModoOscuroTienda" title="Cambiar Tema">
                        <i class="fa-solid fa-moon fs-5"></i>
                    </button>

                    <button class="btn btn-outline-primary position-relative border-0" data-bs-toggle="offcanvas"
                        data-bs-target="#carritoPublicoOffcanvas">
                        <i class="fa-solid fa-cart-shopping fs-5"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                            id="contadorCarritoPublico">
                            0
                        </span>
                    </button>

                    <hr class="d-lg-none my-2 w-100 text-secondary">

                    <% if (cliente) { %>
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle fw-bold text-body" href="#" role="button"
                                data-bs-toggle="dropdown">
                                👤 ¡Hola, <%= cliente.nombre %>!
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/tienda/mis-compras">📦 Mis Pedidos</a></li>
                                <li><a class="dropdown-item" href="/tienda/mi-perfil">⚙️ Mi Perfil</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li><a class="dropdown-item text-danger" href="/tienda/logout">🚪 Salir</a></li>
                            </ul>
                        </div>
                        <% } else { %>
                            <div class="d-flex gap-2">
                                <a href="/tienda/login" class="btn btn-outline-secondary btn-sm fw-bold">Ingresar</a>
                                <a href="/tienda/registro" class="btn btn-primary btn-sm fw-bold">Crear Cuenta</a>
                            </div>
                            <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- BANNER PRINCIPAL MODIFICADO -->
    <div class="bg-primary text-white text-center py-4 mb-4 shadow-sm"
        style="background: linear-gradient(45deg, #0d6efd, #003399) !important;">
        <h1 class="fw-bold m-0 fs-3">🚀 Tecnología de vanguardia al mejor precio 🚀</h1>
        <p class="m-0 opacity-75 small">Envíos a todo el país | Garantía Oficial | Asesoramiento real</p>
    </div>

    <!-- CONTENEDOR PRINCIPAL DEL CATÁLOGO -->
    <div class="container mb-5">
        <div class="row">

            <div class="col-lg-3 mb-4">
                <div class="card bg-body border-0 shadow-sm p-3 rounded-3 sticky-top" style="top: 80px;">
                    <h5 class="fw-bold mb-3 text-body"><i
                            class="fa-solid fa-bars-staggered me-2 text-primary"></i>Categorías</h5>
                    <div class="list-group list-group-flush rounded-3">
                        <a href="javascript:void(0)" onclick="cambiarCategoria('')"
                            class="list-group-item list-group-item-action rounded-2 mb-1 <%= filtrosActuales.categoriaId === '' ? 'active fw-bold' : 'text-body' %>">
                            Todos los Productos
                        </a>
                        <% categorias.forEach(cat=> { %>
                            <a href="javascript:void(0)" onclick="cambiarCategoria('<%= cat.id %>')"
                                class="list-group-item list-group-item-action rounded-2 mb-1 <%= filtrosActuales.categoriaId == cat.id ? 'active fw-bold' : 'text-body' %>">
                                <%= cat.nombre %>
                            </a>
                            <% }) %>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div
                    class="d-flex justify-content-between align-items-center bg-body p-3 rounded-3 shadow-sm mb-4 border border-secondary-subtle">
                    <span class="text-muted fw-bold">
                        <% if(filtrosActuales.busqueda) { %> Resultados para "<%= filtrosActuales.busqueda %>" <% } else
                                    { %> Catálogo completo <% } %>
                    </span>

                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small fw-bold text-nowrap">Ordenar por:</span>
                        <select class="form-select form-select-sm border-secondary shadow-sm" style="width: 200px;"
                            id="selectOrden" onchange="cambiarOrden(this.value)">
                            <option value="nuevos" <%=filtrosActuales.orden==='nuevos' ? 'selected' : '' %>>Más
                                recientes</option>
                            <option value="mas_vendidos" <%=filtrosActuales.orden==='mas_vendidos' ? 'selected' : '' %>
                                >🔥 Más vendidos</option>
                            <option value="precio_asc" <%=filtrosActuales.orden==='precio_asc' ? 'selected' : '' %>
                                >Menor precio</option>
                            <option value="precio_desc" <%=filtrosActuales.orden==='precio_desc' ? 'selected' : '' %>
                                >Mayor precio</option>
                        </select>
                    </div>
                </div>

                <div class="row g-4">
                    <% if (productos && productos.length> 0) { %>
                        <% productos.forEach(prod=> { %>
                            <div class="col-sm-6 col-md-4">
                                <div class="card h-100 border-secondary-subtle shadow-sm card-producto bg-body position-relative"
                                    onclick="window.location.href='/tienda/producto/<%= prod.id %>'">

                                    <% if (Number(prod.porcentaje_descuento)> 0) { %>
                                        <span class="badge bg-success badge-descuento">
                                            <%= Math.round(prod.porcentaje_descuento) %>% OFF
                                        </span>
                                        <% } %>

                                            <div class="contenedor-imagen border-bottom border-secondary-subtle">
                                                <% if (prod.imagen) { %>
                                                    <img src="<%= prod.imagen %>" class="imagen-prod"
                                                        alt="<%= prod.nombre %>">
                                                    <% } else { %>
                                                        <img src="/assets/images/productos/default.png"
                                                            class="imagen-prod" alt="Sin imagen">
                                                        <% } %>
                                            </div>

                                            <div class="card-body d-flex flex-column pt-3">
                                                <h6 class="card-title text-body fw-semibold mb-2"
                                                    style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.4em;"
                                                    title="<%= prod.nombre %>">
                                                    <%= prod.nombre %>
                                                </h6>

                                                <div class="mt-auto">
                                                    <% if (Number(prod.porcentaje_descuento)> 0) { %>
                                                        <small class="text-muted text-decoration-line-through d-block"
                                                            style="font-size: 0.85rem;">
                                                            $<%= Number(prod.precio_venta).toLocaleString('es-AR') %>
                                                        </small>
                                                        <% const precioConDescuento=prod.precio_venta * (1 -
                                                            (prod.porcentaje_descuento / 100)); %>
                                                            <h4 class="fw-bold text-success m-0">$<%=
                                                                    Math.round(precioConDescuento).toLocaleString('es-AR')
                                                                    %>
                                                            </h4>
                                                            <% } else { %>
                                                                <h4 class="fw-bold text-body m-0 mt-3">$<%=
                                                                        Number(prod.precio_venta).toLocaleString('es-AR')
                                                                        %>
                                                                </h4>
                                                                <% } %>

                                                                    <small
                                                                        class="text-muted d-block mt-2 pt-2 border-top border-secondary-subtle"
                                                                        style="font-size: 0.75rem;">
                                                                        <% if (prod.stock_actual> 0) { %>
                                                                            Disponible: <span class="fw-bold text-body">
                                                                                <%= prod.stock_actual %> un.
                                                                            </span>
                                                                            <% } else { %>
                                                                                <span class="text-danger fw-bold"><i
                                                                                        class="fa-solid fa-triangle-exclamation"></i>
                                                                                    Agotado</span>
                                                                                <% } %>
                                                                    </small>
                                                </div>
                                            </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div
                                        class="col-12 text-center py-5 bg-body rounded-3 shadow-sm border border-secondary-subtle">
                                        <i class="fa-solid fa-face-frown-open fa-3x mb-3 text-secondary"></i>
                                        <h5 class="fw-bold text-body">No encontramos productos.</h5>
                                        <p class="small text-muted">Intenta buscar con otras palabras o quita los
                                            filtros.</p>
                                        <button class="btn btn-outline-primary fw-bold mt-2"
                                            onclick="window.location.href='/tienda'">Limpiar Búsqueda</button>
                                    </div>
                                    <% } %>
                </div>

                <% if (filtrosActuales.totalPaginas> 1) { %>
                    <div class="d-flex justify-content-center mt-5">
                        <nav>
                            <ul class="pagination pagination-md shadow-sm">
                                <li class="page-item <%= filtrosActuales.paginaActual === 1 ? 'disabled' : '' %>">
                                    <a class="page-link fw-bold" href="javascript:void(0)"
                                        onclick="cambiarPagina(<%= filtrosActuales.paginaActual - 1 %>)">Anterior</a>
                                </li>
                                <% for(let i=1; i <=filtrosActuales.totalPaginas; i++) { %>
                                    <li class="page-item <%= filtrosActuales.paginaActual === i ? 'active' : '' %>">
                                        <a class="page-link fw-bold" href="javascript:void(0)"
                                            onclick="cambiarPagina(<%= i %>)">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>
                                        <li
                                            class="page-item <%= filtrosActuales.paginaActual === filtrosActuales.totalPaginas ? 'disabled' : '' %>">
                                            <a class="page-link fw-bold" href="javascript:void(0)"
                                                onclick="cambiarPagina(<%= filtrosActuales.paginaActual + 1 %>)">Siguiente</a>
                                        </li>
                            </ul>
                        </nav>
                    </div>
                    <% } %>
            </div>
        </div>
    </div>

    <!-- SECCIÓN NOSOTROS (Cuerpo de la Landing Page) -->
    <div class="container-fluid bg-body my-5 py-5 border-top border-bottom border-secondary-subtle shadow-sm">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
                    <span class="text-primary fw-bold small text-uppercase tracking-wider">Nuestra Historia</span>
                    <h2 class="fw-bold text-body mb-3 mt-2">Tecnología confiable, atención cercana.</h2>
                    <p class="lead text-muted">En <strong>Tienda Electrónica</strong> nacimos con una misión simple:
                        acercar equipos y hardware de primer nivel a cada persona, desde estudiantes hasta
                        profesionales.</p>
                    <p class="text-muted">Empezamos con pocos productos en un showroom local, pero con un estándar
                        innegociable: excelente atención, garantía real y recomendaciones con criterio. Hoy contamos con
                        puntos de venta oficiales y despachamos de manera constante a todo el país.</p>

                    <div class="d-flex align-items-center mt-4">
                        <div class="bg-primary-subtle text-primary p-3 rounded-circle me-3">
                            <i class="fa-solid fa-headset fa-xl"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold m-0 text-body">Asesoramiento Real</h6>
                            <small class="text-muted">Te guiamos según tu objetivo y presupuesto.</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mt-3">
                        <div class="bg-success-subtle text-success p-3 rounded-circle me-3">
                            <i class="fa-solid fa-truck-fast fa-xl"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold m-0 text-body">Envíos Rápidos</h6>
                            <small class="text-muted">A la puerta de tu casa con seguimiento online.</small>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div
                                class="p-4 bg-body-tertiary border border-secondary-subtle rounded-3 shadow-sm h-100 text-center">
                                <i class="fa-solid fa-medal fa-2x text-primary mb-3"></i>
                                <h6 class="fw-bold text-body">Calidad</h6>
                                <small class="text-muted">Solo trabajamos con marcas reconocidas y equipos
                                    verificados.</small>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div
                                class="p-4 bg-body-tertiary border border-secondary-subtle rounded-3 shadow-sm h-100 text-center">
                                <i class="fa-solid fa-handshake fa-2x text-primary mb-3"></i>
                                <h6 class="fw-bold text-body">Transparencia</h6>
                                <small class="text-muted">Te asesoramos con info clara y honesta, sin presión de
                                    venta.</small>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div
                                class="p-4 bg-body-tertiary border border-secondary-subtle rounded-3 shadow-sm h-100 text-center">
                                <i class="fa-solid fa-truck fa-2x text-primary mb-3"></i>
                                <h6 class="fw-bold text-body">Accesibilidad</h6>
                                <small class="text-muted">Comprá fácil con métodos de pago seguros y logística
                                    ágil.</small>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div
                                class="p-4 bg-body-tertiary border border-secondary-subtle rounded-3 shadow-sm h-100 text-center">
                                <i class="fa-solid fa-star fa-2x text-primary mb-3"></i>
                                <h6 class="fw-bold text-body">Compromiso</h6>
                                <small class="text-muted">No vendemos promesas, tu experiencia es nuestra
                                    prioridad.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- BOTÓN VOLVER ARRIBA -->
    <button onclick="subirArriba()" id="btnVolverArriba" title="Ir arriba">
        <i class="fa-solid fa-arrow-up"></i>
    </button>

    <!-- FOOTER PROFESIONAL (Estilo Imagen) -->
    <footer class="bg-dark text-white mt-auto pt-5 pb-4 border-top border-secondary border-opacity-25">
        <div class="container text-center text-md-start">
            <div class="row text-center text-md-start align-items-center">

                <!-- DATA FISCAL -->
                <div
                    class="col-md-3 col-lg-3 col-xl-3 mx-auto mb-4 border-end border-secondary border-opacity-50 text-center">
                    <img src="https://www.afip.gob.ar/images/f960/DATAWEB.jpg" alt="Data Fiscal" style="width: 80px;"
                        class="mb-3 rounded">
                    <p class="small text-muted mb-0">Consumidor protegido</p>
                </div>

                <!-- AYUDA / LEGALES -->
                <div
                    class="col-md-3 col-lg-3 col-xl-3 mx-auto mb-4 border-end border-secondary border-opacity-50 text-center text-md-start px-md-4">
                    <a href="/tienda/ayuda" class="btn btn-light btn-sm fw-bold mb-3 w-75 rounded-pill">Centro de Ayuda</a>
                    <p class="mb-2">
                        <a href="/tienda/arrepentimiento"
                            class="text-white text-decoration-none border border-white rounded-pill px-3 py-1 d-inline-block small"
                            style="background-color: transparent;">Botón de arrepentimiento</a>
                    </p>
                    <p class="mb-0">
                        <a href="/tienda/terminos-y-condiciones"
                            class="text-white text-decoration-underline small">Términos y condiciones</a>
                    </p>
                </div>

                <!-- REDES SOCIALES -->
                <div
                    class="col-md-3 col-lg-3 col-xl-3 mx-auto mb-4 border-end border-secondary border-opacity-50 text-center">
                    <h6 class="text-uppercase mb-3 fw-bold">Seguinos en</h6>
                    <div class="d-flex justify-content-center flex-wrap gap-2">
                        <a href="#" class="footer-social-icon"><i class="fa-brands fa-x-twitter"></i></a>
                        <a href="#" class="footer-social-icon"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="footer-social-icon"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="footer-social-icon"><i class="fa-brands fa-youtube"></i></a>
                        <a href="#" class="footer-social-icon mt-2"><i class="fa-brands fa-linkedin-in"></i></a>
                        <a href="#" class="footer-social-icon mt-2"><i class="fa-brands fa-tiktok"></i></a>
                        <a href="#" class="footer-social-icon mt-2"><i class="fa-brands fa-twitch"></i></a>
                    </div>
                </div>
            </div>
            <hr class="mb-4 border-secondary">
            <div class="row align-items-center">
                <div class="col-12 text-center">
                    <p class="small text-muted mb-0">Copyright © 2026 Todos los derechos reservados por Tienda
                        Electrónica S.A.</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- CARRITO OFFCANVAS -->
    <button class="btn btn-primary shadow-lg position-fixed d-flex justify-content-center align-items-center"
        style="bottom: 30px; right: 30px; width: 65px; height: 65px; border-radius: 50%; z-index: 1040;" type="button"
        data-bs-toggle="offcanvas" data-bs-target="#carritoPublicoOffcanvas" title="Ver Carrito">
        <i class="fa-solid fa-cart-shopping fs-3"></i>
        <span id="contadorCarritoFlotante"
            class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light"
            style="font-size: 0.9rem;">
            0
        </span>
    </button>

    <div class="offcanvas offcanvas-end shadow-lg" tabindex="-1" id="carritoPublicoOffcanvas">
        <div class="offcanvas-header bg-primary text-white">
            <h5 class="offcanvas-title fw-bold"><i class="fa-solid fa-cart-shopping me-2"></i>Mi Carrito</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column bg-body-tertiary p-0">
            <div id="listaCarritoPublico" class="flex-grow-1 overflow-auto p-3">
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-cart-arrow-down fa-3x mb-3 text-secondary"></i>
                    <h6>Tu carrito está vacío</h6>
                    <p class="small">¡Agregá productos para empezar tu compra!</p>
                </div>
            </div>

            <div class="bg-body p-3 border-top shadow-sm">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold m-0 text-body">Total a pagar:</h5>
                    <h5 class="fw-bold text-success m-0" id="totalCarritoPublico">$0.00</h5>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg fw-bold" onclick="iniciarCheckout()">
                        Iniciar Compra <i class="fa-solid fa-arrow-right ms-2"></i>
                    </button>
                    <button class="btn btn-outline-danger fw-bold" onclick="vaciarCarritoPublico()">
                        Vaciar Carrito
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/assets/js/carrito_publico.js"></script>

    <script>
        // MODO OSCURO
        document.addEventListener('DOMContentLoaded', () => {
            const htmlElement = document.documentElement;
            const btnModoOscuro = document.getElementById('btnModoOscuroTienda');
            const iconoTema = btnModoOscuro.querySelector('i');

            const temaGuardado = localStorage.getItem('temaTienda');
            if (temaGuardado === 'dark') {
                htmlElement.setAttribute('data-bs-theme', 'dark');
                iconoTema.classList.replace('fa-moon', 'fa-sun');
            } else {
                htmlElement.setAttribute('data-bs-theme', 'light');
            }

            btnModoOscuro.addEventListener('click', () => {
                const temaActual = htmlElement.getAttribute('data-bs-theme');
                if (temaActual === 'light') {
                    htmlElement.setAttribute('data-bs-theme', 'dark');
                    localStorage.setItem('temaTienda', 'dark');
                    iconoTema.classList.replace('fa-moon', 'fa-sun');
                } else {
                    htmlElement.setAttribute('data-bs-theme', 'light');
                    localStorage.setItem('temaTienda', 'light');
                    iconoTema.classList.replace('fa-sun', 'fa-moon');
                }
            });
        });

        // ===============================================
        // BOTÓN VOLVER ARRIBA (LÓGICA SCROLL)
        // ===============================================
        window.onscroll = function () {
            let botonArriba = document.getElementById("btnVolverArriba");
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                botonArriba.style.display = "block";
            } else {
                botonArriba.style.display = "none";
            }
        };

        function subirArriba() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ===============================================
        // MOTOR DE BÚSQUEDA Y FILTROS JAVASCRIPT
        // ===============================================
        let filtros = {
            busqueda: "<%= filtrosActuales.busqueda %>",
            categoria: "<%= filtrosActuales.categoriaId %>",
            orden: "<%= filtrosActuales.orden %>",
            pagina: "<%= filtrosActuales.paginaActual %>"
        };

        function ejecutarFiltro() {
            let url = `/tienda?`;
            if (filtros.busqueda) url += `busqueda=${encodeURIComponent(filtros.busqueda)}&`;
            if (filtros.categoria) url += `categoria=${filtros.categoria}&`;
            if (filtros.orden) url += `orden=${filtros.orden}&`;
            if (filtros.pagina > 1) url += `pagina=${filtros.pagina}&`;

            window.location.href = url;
        }

        function aplicarFiltros(e) {
            e.preventDefault();
            filtros.busqueda = document.getElementById('inputBusqueda').value;
            filtros.pagina = 1;
            ejecutarFiltro();
        }

        function cambiarCategoria(idCategoria) {
            filtros.categoria = idCategoria;
            filtros.pagina = 1;
            ejecutarFiltro();
        }

        function cambiarOrden(nuevoOrden) {
            filtros.orden = nuevoOrden;
            filtros.pagina = 1;
            ejecutarFiltro();
        }

        function cambiarPagina(numeroPagina) {
            filtros.pagina = numeroPagina;
            ejecutarFiltro();
        }
    </script>
</body>

</html>