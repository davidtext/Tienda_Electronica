<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Remito #<%= id_venta %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        /* Estilos específicos para que la impresora no gaste tinta y se vea profesional */
        body { background-color: #fff; color: #000; font-family: Arial, sans-serif; }
        .etiqueta-container { max-width: 800px; margin: 0 auto; border: 2px solid #000; padding: 20px; border-radius: 8px; }
        .barcode { font-family: 'Libre Barcode 39', monospace; font-size: 50px; line-height: 1; letter-spacing: 5px; }
        .box-negro { border: 2px solid #000; padding: 15px; margin-bottom: 15px; border-radius: 5px; }
        .bg-negro { background-color: #000 !important; color: #fff !important; padding: 5px 10px; font-weight: bold; }
        
        /* Ocultar elementos innecesarios al imprimir */
        @media print {
            .no-print { display: none !important; }
            body { margin: 0; padding: 0; }
            .etiqueta-container { border: none; padding: 0; }
        }
    </style>
</head>
<body>

    <div class="text-center my-4 no-print">
        <button class="btn btn-primary btn-lg fw-bold px-5" onclick="window.print()">
            <i class="fa-solid fa-print me-2"></i> Imprimir Etiqueta
        </button>
        <button class="btn btn-outline-secondary btn-lg ms-2" onclick="window.close()">Cerrar</button>
    </div>

    <div class="etiqueta-container">
        
        <div class="d-flex justify-content-between align-items-end mb-3 border-bottom border-dark pb-3">
            <div>
                <h2 class="fw-bold m-0 text-uppercase">ORDEN #<%= id_venta %></h2>
                <span class="fw-bold">TIENDA ELECTRÓNICA SRL</span><br>
                <small>Av. Siempreviva 123, Formosa</small>
            </div>
            <div class="text-end">
                <span class="bg-negro d-inline-block mb-1">ENVÍO A DOMICILIO</span><br>
                <span class="barcode">*TE-<%= id_venta %>*</span>
            </div>
        </div>

        <div class="box-negro">
            <h6 class="bg-negro d-inline-block m-0 mb-2">DESTINATARIO / RECIBE</h6>
            <h1 class="fw-bold m-0 text-uppercase"><%= cabecera.nombre %> <%= cabecera.apellido %></h1>
            <h4 class="fw-bold m-0 mt-2"><i class="fa-solid fa-location-dot me-2"></i><%= cabecera.calle %> <%= cabecera.numero %></h4>
            <h5 class="m-0 mt-1 text-uppercase">
                <%- cabecera.piso_depto ? `Depto: <strong>${cabecera.piso_depto}</strong> | ` : '' %> 
                CP: <%= cabecera.codigo_postal %>
            </h5>
            <h5 class="m-0 mt-1"><%= cabecera.ciudad %>, <%= cabecera.provincia %></h5>
            
            <hr class="border-dark">
            <div class="d-flex justify-content-between fs-5">
                <span><strong>DNI:</strong> <%= cabecera.dni_cuil %></span>
                <span><strong>TEL:</strong> <%= cabecera.telefono || 'Sin teléfono' %></span>
            </div>
        </div>

        <div class="box-negro">
            <h6 class="bg-negro d-inline-block m-0 mb-2">ESTADO DE COBRO</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="m-0 text-uppercase">
                    <% if (cabecera.estado === 'Pendiente' && cabecera.metodo_pago.includes('Efectivo')) { %>
                        <strong>❌ A COBRAR EN PUERTA:</strong>
                    <% } else { %>
                        <strong>✅ PAGADO VÍA:</strong> <%= cabecera.metodo_pago %>
                    <% } %>
                </h4>
                <h2 class="fw-bold m-0">$<%= Number(cabecera.total_venta).toLocaleString('es-AR') %></h2>
            </div>
        </div>

        <div class="box-negro">
            <h6 class="bg-negro d-inline-block m-0 mb-2">CONTENIDO DEL PAQUETE</h6>
            <table class="table table-sm table-borderless m-0 fs-6">
                <tbody>
                    <% detalles.forEach(item => { %>
                        <tr class="border-bottom border-dark">
                            <td class="fw-bold" style="width: 10%;"><%= item.cantidad %>x</td>
                            <td><%= item.nombre %></td>
                            <td class="text-end text-muted small">SKU: <%= item.sku %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        window.onload = function() {
            window.print();
        };
    </script>
</body>
</html>