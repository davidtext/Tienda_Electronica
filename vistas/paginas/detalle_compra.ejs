<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle de Compra #<%= venta.id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="bg-body-tertiary">

    <nav class="navbar navbar-expand-lg bg-body shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/tienda">🛒 Tienda Online</a>
            <div class="navbar-nav ms-auto align-items-center gap-3">
                <a href="/tienda/mis-compras" class="btn btn-sm btn-outline-secondary fw-bold"><i class="fa-solid fa-arrow-left me-1"></i> Volver a mis compras</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold m-0">Detalle de Orden #<%= venta.id %></h4>
            <span class="badge bg-primary fs-6"><%= venta.estado %></span>
        </div>

        <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
            <div class="card-body p-4 bg-primary text-white" style="border-radius: 12px;">
                <h5 class="fw-bold mb-1"><i class="fa-solid fa-truck-fast me-2"></i> Estado: <%= venta.estado_envio %></h5>
                <p class="m-0 opacity-75 small">Fecha de compra: <%= new Date(venta.fecha_hora).toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute:'2-digit' }) %></p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-7">
                <div class="card border-secondary-subtle shadow-sm h-100">
                    <div class="card-header bg-body border-bottom fw-bold">Productos en tu pedido</div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            <% detalles.forEach(item => { %>
                                <li class="list-group-item p-3 d-flex align-items-center">
                                    <img src="<%= item.imagen %>" alt="Producto" class="rounded border me-3" style="width: 50px; height: 50px; object-fit: contain;">
                                    <div class="flex-grow-1">
                                        <h6 class="m-0 fw-semibold text-truncate" style="max-width: 250px;"><%= item.nombre %></h6>
                                        <small class="text-muted"><%= item.cantidad %> un. x $<%= Number(item.precio_unitario).toLocaleString('es-AR') %></small>
                                    </div>
                                    <span class="fw-bold text-success">$<%= Number(item.subtotal).toLocaleString('es-AR') %></span>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card border-secondary-subtle shadow-sm mb-4">
                    <div class="card-header bg-body border-bottom fw-bold">Resumen de pago</div>
                    <div class="card-body bg-body-tertiary">
                        <div class="d-flex justify-content-between mb-2 small text-muted">
                            <span>Medio de pago:</span>
                            <span class="text-end fw-semibold"><%= venta.metodo_pago %></span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 mt-2">
                            <span class="fw-bold">Total pagado:</span>
                            <span class="fw-bold text-success fs-5">$<%= Number(venta.total_venta).toLocaleString('es-AR') %></span>
                        </div>
                    </div>
                </div>

                <div class="card border-secondary-subtle shadow-sm">
                    <div class="card-header bg-body border-bottom fw-bold">Datos de entrega</div>
                    <div class="card-body small">
                        <% if (venta.calle) { %>
                            <p class="m-0 fw-bold text-primary mb-1"><i class="fa-solid fa-location-dot me-1"></i> <%= venta.alias %></p>
                            <p class="m-0 text-muted"><%= venta.calle %> <%= venta.numero %></p>
                            <p class="m-0 text-muted"><%= venta.ciudad %>, <%= venta.provincia %></p>
                            <p class="m-0 text-muted">CP: <%= venta.codigo_postal %></p>
                        <% } else { %>
                            <p class="m-0 fw-bold text-primary mb-1"><i class="fa-solid fa-store me-1"></i> Retiro en Local</p>
                            <p class="m-0 text-muted">Av. Siempreviva 123</p>
                            <p class="m-0 text-muted">Presentar DNI y Nro de Orden.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>