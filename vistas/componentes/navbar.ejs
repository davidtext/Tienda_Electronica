        <li class="nav-item"><a class="nav-link" href="/historial">Ventas</a></li>
        <li class="nav-item"><a class="nav-link" href="/clientes">Clientes</a></li>
        <li class="nav-item"><a class="nav-link" href="/pedidos-web">Pedidos web</a></li>

        <% if (usuario.rol_id===1) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown"
              aria-expanded="false">
              ⚙️ Administración
            </a>
            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
              <li><a class="dropdown-item" href="/usuarios">👤 Gestion Personal</a></li>
              <li><a class="dropdown-item" href="/gestion-productos">📦 Gestion productos</a></li>
              <li><a class="dropdown-item" href="/parametros">🏷️ Gestion Categorías y Marcas</a></li>
              <li><a class="dropdown-item" href="/stock/ingresos">📥 Ingresar Stock</a></li>
              <li><a class="dropdown-item" href="/stock-defectuoso">🗑️ Stock defectuoso</a></li>
              <li><a class="dropdown-item" href="/auditoria">📝 Auditoría (Log)</a></li>
