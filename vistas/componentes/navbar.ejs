          </li>
          <% } %>
      </ul>

      <div class="d-flex align-items-center ms-3">

        <a href="/pedidos-web" class="btn btn-outline-primary border-0 me-2 position-relative"
          title="Pedidos Web Pendientes">
          <i class="fa-solid fa-bell fs-5"></i>
          <span id="badgeNotificaciones"
            class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
            style="font-size: 0.65rem;">
            0
          </span>
        </a>

        <button class="btn btn-outline-secondary border-0 me-3" id="btnModoOscuro" title="Cambiar Tema">
          <i class="fa-solid fa-moon fs-5"></i>
        </button>

