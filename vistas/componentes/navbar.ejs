<script>
  document.addEventListener('DOMContentLoaded', () => {
    const htmlElement = document.documentElement;
    const btnModoOscuro = document.getElementById('btnModoOscuro');
    const iconoTema = btnModoOscuro.querySelector('i');

    // 1. Revisar si el usuario ya tenía un tema guardado
    const temaGuardado = localStorage.getItem('temaTienda');
    if (temaGuardado === 'dark') {
      htmlElement.setAttribute('data-bs-theme', 'dark');
      iconoTema.classList.replace('fa-moon', 'fa-sun');
    } else {
      htmlElement.setAttribute('data-bs-theme', 'light');
    }

    // 2. Cambiar el tema al hacer clic
    btnModoOscuro.addEventListener('click', () => {
      const temaActual = htmlElement.getAttribute('data-bs-theme');
      if (temaActual === 'light') {
        htmlElement.setAttribute('data-bs-theme', 'dark');
        localStorage.setItem('temaTienda', 'dark');
        iconoTema.classList.replace('fa-moon', 'fa-sun');
      } else {
        htmlElement.setAttribute('data-bs-theme', 'light');
        localStorage.setItem('temaTienda', 'light');
        iconoTema.classList.replace('fa-sun', 'fa-moon');
      }
    });

    // ==========================================
    // 🔔 SISTEMA DE NOTIFICACIONES EN VIVO (POLLING)
    // ==========================================
    const badgeNotificaciones = document.getElementById('badgeNotificaciones');
    let cantidadAnterior = 0; // Memoria para saber si entró uno NUEVO

    // Creamos un audio invisible para el "Ding" de caja registradora
    const sonidoNotificacion = new Audio('https://actions.google.com/sounds/v1/alarms/beep_short.ogg');
    sonidoNotificacion.volume = 0.5;

    function revisarPedidosPendientes() {
      fetch('/api/notificaciones/pedidos-pendientes')
        .then(res => res.json())
        .then(data => {
          if (data.status === 'success') {
            const cantidadActual = data.cantidad;

            // Si hay más de 0, mostramos la bolita roja
            if (cantidadActual > 0) {
              badgeNotificaciones.textContent = cantidadActual;
              badgeNotificaciones.classList.remove('d-none');

              // Si la cantidad subió (entró un pedido nuevo), hacemos sonar el DING!
              if (cantidadActual > cantidadAnterior) {
                sonidoNotificacion.play().catch(e => console.log('El navegador bloqueó el sonido automático.'));
              }
            } else {
              // Si no hay pedidos, ocultamos la bolita
              badgeNotificaciones.classList.add('d-none');
            }

            cantidadAnterior = cantidadActual; // Actualizamos la memoria
          }
        })
        .catch(err => console.error('Error buscando notificaciones', err));
    }

    // Ejecutamos la búsqueda de inmediato al cargar la página
    revisarPedidosPendientes();

    // Hacemos que busque silenciosamente cada 15 segundos (15000 milisegundos)
    setInterval(revisarPedidosPendientes, 15000);
  });
</script>